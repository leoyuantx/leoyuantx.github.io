}

// ---- Secret System ----
// Each hole has a hidden crystal. Easy levels: just hit it. Hard levels: hit pattern targets in order.
// The pattern rule: targets must be hit in order based on (holeNum + 1) — e.g., hole 1 = hit 1 target,
// hole 2 = hit 2 targets in order (left-to-right), hole 3 = hit 3 targets.
// But the *hidden pattern* across tournaments: secret position follows a spiral from center outward.
// Players who notice: secrets move clockwise from center each tournament.

let secretData = null;  // { type, crystal: {x,z}, targets: [{x,z}], found, patternProgress, reward }
let secretMesh = null;
let secretTargetMeshes = [];
let secretFound = false;
let secretPatternProgress = 0;

// ---- Sparkle Lights System ----
let sparkleLights = []; // { x, z, reward, collected, mesh, glowMesh }

function generateSecret(courseData, difficulty, holeNum, tIdx) {
  const seed = tIdx * 1000 + holeNum * 7 + 42;
  const rng = mulberry32(seed);

  // Secret crystal position — follows a spiral pattern from center
  // The hidden pattern: angle = (tIdx * 137.5 + holeNum * 60) degrees (golden angle based)
  // Distance from center increases with tournament index
  const spiralAngle = ((tIdx * 137.5 + holeNum * 60) % 360) * Math.PI / 180;
  const spiralDist = 3 + (tIdx % 5) * 2.5 + holeNum * 1.5;
  let cx = CW / 2 + Math.cos(spiralAngle) * Math.min(spiralDist, CW / 2 - 3);
  let cz = CH / 2 + Math.sin(spiralAngle) * Math.min(spiralDist, CH / 2 - 3);
  // Clamp to course bounds
  cx = Math.max(2, Math.min(CW - 2, cx));
  cz = Math.max(2, Math.min(CH - 2, cz));

  // Make sure crystal isn't too close to ball start or hole
  if (dist(cx, cz, courseData.bx, courseData.bz) < 3) {
    cx = (cx + CW / 2) / 2;
    cz = (cz + CH / 2) / 2;
  }
  if (dist(cx, cz, courseData.hx, courseData.hz) < 3) {
    cx = (cx + courseData.bx) / 2;
    cz = (cz + courseData.bz) / 2;
  }

  const isHard = difficulty >= 3;
  const reward = 25 + Math.floor(rng() * 50); // 25-75 bonus coins

  if (!isHard) {
    // Easy: just hit the crystal directly
    return {
      type: 'simple',
      crystal: { x: cx, z: cz, r: 0.4 },
      targets: [],
      found: false,
      patternProgress: 0,
      reward,
      hint: 'Something glimmers nearby...',
    };
  } else {
    // Hard: hit pattern targets in order before crystal appears clearly
    // Number of targets = 1 + (holeNum % 3), max 3
    const numTargets = 1 + (holeNum % 3);
    const targets = [];
    for (let i = 0; i < numTargets; i++) {
      // Place targets in a clockwise arc around the crystal
      const tAngle = spiralAngle + (i + 1) * (Math.PI * 2 / (numTargets + 1));
      let tx = cx + Math.cos(tAngle) * (3 + rng() * 2);
      let tz = cz + Math.sin(tAngle) * (3 + rng() * 2);
      tx = Math.max(1.5, Math.min(CW - 1.5, tx));
      tz = Math.max(1.5, Math.min(CH - 1.5, tz));
      targets.push({ x: tx, z: tz, r: 0.35, hit: false });
    }
    return {
      type: 'pattern',
      crystal: { x: cx, z: cz, r: 0.4 },
      targets,
      found: false,
      patternProgress: 0,
      reward,
      hint: `Hit ${numTargets} rune${numTargets > 1 ? 's' : ''} in the right order...`,
    };
  }
}

// ---- Raycaster for mouse -> ground plane ----
const raycaster = new THREE.Raycaster();
const mousev = new THREE.Vector2();
const groundPlane = new THREE.Plane(new THREE.Vector3(0, 1, 0), 0);
let mouseWorldX = CW / 2, mouseWorldZ = CH / 2;

renderer.domElement.addEventListener('mousemove', e => {
  mousev.x = (e.clientX / window.innerWidth) * 2 - 1;
  mousev.y = -(e.clientY / window.innerHeight) * 2 + 1;
  raycaster.setFromCamera(mousev, camera);
  const target = new THREE.Vector3();
  raycaster.ray.intersectPlane(groundPlane, target);
  if (target) {
    mouseWorldX = target.x;
    mouseWorldZ = target.z;
  }
});

renderer.domElement.addEventListener('mousedown', e => {
  e.preventDefault();
  initAudio();
  if (gamePhase === 'aiming') {
    aimAngle = Math.atan2(mouseWorldZ - ball.z, mouseWorldX - ball.x);
    gamePhase = 'powering';
    power = 0;
    tapCount = 0;
    powerBar.classList.remove('hidden');
    tapHint.classList.remove('hidden');
    powerFill.style.width = '0%';
    powerLabel.textContent = 'TAP to increase power! Right-click or Space to shoot.';
    tapCount++;
    power = Math.min(tapCount * 5, 100);
    powerFill.style.width = power + '%';
    playTapSound();
  } else if (gamePhase === 'powering') {
    tapCount++;
    power = Math.min(tapCount * 5, 100);
    powerFill.style.width = power + '%';
    playTapSound();
  }
});

renderer.domElement.addEventListener('contextmenu', e => {
  e.preventDefault();
  if (gamePhase === 'powering') launchBall();
});

document.addEventListener('keydown', e => {
  if (e.code === 'Space' && gamePhase === 'powering') {
    e.preventDefault();
    launchBall();
  }
});

function launchBall() {
  if (power <= 0) return;
  savedSpeed = 0.08 + (power / 100) * 0.45;
  savedAngle = aimAngle;
  gamePhase = 'swinging';
  powerBar.classList.add('hidden');
  tapHint.classList.add('hidden');
  powerLabel.textContent = '';
  playSwingSound();
  startClubSwing();
}

function startClubSwing() {
  // Position club behind ball, facing aim direction
  clubPivot.position.set(ball.x, 0, ball.z);
  clubPivot.rotation.set(0, 0, 0);
  clubGroup.rotation.set(0, 0, 0);
  clubGroup.visible = true;

  // Rotate the whole pivot so club faces the aim direction
  clubPivot.rotation.y = -savedAngle + Math.PI / 2;

  clubSwinging = true;
  clubSwingStart = Date.now();
  pendingLaunch = true;
}

function updateClubSwing() {
  if (!clubSwinging) return;
  const elapsed = Date.now() - clubSwingStart;
  const t = Math.min(elapsed / SWING_DURATION, 1.0);

  let swingAngle;
  if (t < 0.45) {
    // Backswing
    const bt = t / 0.45;
    swingAngle = SWING_BACK_ANGLE * easeOutCubic(bt);
  } else if (t < 0.65) {
    // Hit zone - fast forward swing
    const ht = (t - 0.45) / 0.2;
    swingAngle = SWING_BACK_ANGLE + (SWING_HIT_ANGLE - SWING_BACK_ANGLE) * easeInCubic(ht);
    // Launch ball at the hit point
    if (pendingLaunch && ht > 0.7) {
      pendingLaunch = false;
      ball.vx = Math.cos(savedAngle) * savedSpeed;
      ball.vz = Math.sin(savedAngle) * savedSpeed;
      strokes++;
      lightsCollectedThisStroke = 0;
      strokesLabelEl.textContent = `Strokes: ${strokes}`;
      gamePhase = 'rolling';
      playHitSound();
    }
  } else {
    // Follow through
    const ft = (t - 0.65) / 0.35;
    swingAngle = SWING_HIT_ANGLE + Math.PI * 0.1 * easeOutCubic(ft);
  }

  clubGroup.rotation.x = swingAngle;

  if (t >= 1.0) {
    clubSwinging = false;
    clubGroup.visible = false;
    if (pendingLaunch) {
      pendingLaunch = false;
      ball.vx = Math.cos(savedAngle) * savedSpeed;
      ball.vz = Math.sin(savedAngle) * savedSpeed;
      strokes++;
      lightsCollectedThisStroke = 0;
      strokesLabelEl.textContent = `Strokes: ${strokes}`;
      gamePhase = 'rolling';
      playHitSound();
    }
  }
}

function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }
function easeInCubic(t) { return t * t * t; }

// ---- Course Generation ----
function mulberry32(a) {
  return function() {
    a |= 0; a = a + 0x6D2B79F5 | 0;
    let t = Math.imul(a ^ a >>> 15, 1 | a);
    t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
    return ((t ^ t >>> 14) >>> 0) / 4294967296;
  };
}

function dist(x1, z1, x2, z2) {
  return Math.sqrt((x1-x2)**2 + (z1-z2)**2);
}

function generateCourses(tournamentIdx) {
  const courses = [];
  const difficulty = Math.min(tournamentIdx, 8);
  for (let h = 0; h < holesPerTournament; h++) {
    courses.push(generateHole(difficulty, h, tournamentIdx));
  }
  return courses;
}

function generateHole(difficulty, holeNum, tIdx) {
  const seed = tIdx * 100 + holeNum;
  const rng = mulberry32(seed);

  const bx = 3 + rng() * 5;
  const bz = CH - 4 - rng() * 3;

  const hx = CW - 6 + rng() * 3;
  const hz = 3 + rng() * 5;

  const obs = [];
  const numObs = 4 + Math.floor(difficulty * 0.8) + holeNum;

  for (let i = 0; i < numObs; i++) {
    const type = rng() < 0.5 ? 'rect' : 'circle';
    if (type === 'rect') {
      const w = 1.5 + rng() * (2.5 + difficulty * 0.4);
      const d = 0.8 + rng() * (1.2 + difficulty * 0.2);
      const x = 5 + rng() * (CW - 12);
      const z = 5 + rng() * (CH - 12);
      if (dist(x, z, bx, bz) > 4 && dist(x, z, hx, hz) > 4) {
        obs.push({ type: 'rect', x, z, w, d, h: 0.5 + rng() * 0.6 });
      }
    } else {
      const r = 0.6 + rng() * (1.0 + difficulty * 0.15);
      const x = 5 + rng() * (CW - 12);
      const z = 5 + rng() * (CH - 12);
      if (dist(x, z, bx, bz) > 4 && dist(x, z, hx, hz) > 4) {
        obs.push({ type: 'circle', x, z, r });
      }
    }
  }

  const wallList = [];
  if (difficulty >= 0) {
    const numWalls = Math.max(1, Math.floor(difficulty / 2) + 1);
    for (let i = 0; i < numWalls; i++) {
      const wx = 6 + rng() * (CW - 14);
      const wz = 6 + rng() * (CH - 14);
      const horizontal = rng() > 0.5;
      const len = 3 + rng() * (4 + difficulty * 0.7);
      const wall = horizontal
        ? { x1: wx, z1: wz, x2: wx + len, z2: wz }
        : { x1: wx, z1: wz, x2: wx, z2: wz + len };
      if (dist(wx, wz, bx, bz) > 3 && dist(wx, wz, hx, hz) > 3) {
        wallList.push(wall);
      }
    }
  }

  const par = 2 + Math.floor(numObs / 2) + (wallList.length > 1 ? 1 : 0);

  return { bx, bz, hx, hz, obs, walls: wallList, par };
}

let courses = [];

// ---- Build 3D Course ----
function buildCourse3D(courseData) {
  // Clear old course
  scene.remove(courseGroup);
  courseGroup = new THREE.Group();
  scene.add(courseGroup);
  flagMeshRef = null;
  // Clean up old fish & splashes from scene
  fishList.forEach(f => { scene.remove(f.mesh); });
  fishList = [];
  splashParticles.forEach(sp => { scene.remove(sp.mesh); });
  splashParticles = [];
  waterMeshRefs = [];

  // Green surface with slight elevation
  const surfaceGeo = new THREE.BoxGeometry(CW, 0.25, CH);
  const surface = new THREE.Mesh(surfaceGeo, grassMat);
  surface.position.set(CW / 2, -0.125, CH / 2);
  surface.receiveShadow = true;
  courseGroup.add(surface);

  // Fringe (slightly rough grass around course edge) with its own texture
  const fringeTexCanvas = document.createElement('canvas');
  fringeTexCanvas.width = 256; fringeTexCanvas.height = 256;
  const fringeCtx = fringeTexCanvas.getContext('2d');
  // Darker, rougher base than putting green
  const fringeBase = fringeCtx.createLinearGradient(0, 0, 256, 256);
  fringeBase.addColorStop(0, '#1e6e38'); fringeBase.addColorStop(0.5, '#257840'); fringeBase.addColorStop(1, '#1a6430');
  fringeCtx.fillStyle = fringeBase;
  fringeCtx.fillRect(0, 0, 256, 256);
  // Color clumps
  for (let i = 0; i < 20; i++) {
    const px = Math.random() * 256, py = Math.random() * 256;
    const pr = 15 + Math.random() * 35;
    const hue = 85 + Math.random() * 50;
    const lit = 16 + Math.random() * 18;
    const pg = fringeCtx.createRadialGradient(px, py, 0, px, py, pr);
    pg.addColorStop(0, `hsla(${hue}, 45%, ${lit}%, 0.2)`);
    pg.addColorStop(1, `hsla(${hue}, 45%, ${lit}%, 0)`);
    fringeCtx.fillStyle = pg;
    fringeCtx.fillRect(px - pr, py - pr, pr * 2, pr * 2);
  }
  // Thick, rough blades (taller than putting green)
  for (let i = 0; i < 2200; i++) {
    const bx = Math.random() * 256, by = Math.random() * 256;
    const bl = 5 + Math.random() * 14;
    const hue = 80 + Math.random() * 55;
    const sat = 35 + Math.random() * 35;
    const lit = 16 + Math.random() * 26;
    fringeCtx.strokeStyle = `hsla(${hue}, ${sat}%, ${lit}%, ${0.15 + Math.random() * 0.22})`;
    fringeCtx.lineWidth = 0.8 + Math.random() * 1.5;
    fringeCtx.lineCap = 'round';
    fringeCtx.beginPath(); fringeCtx.moveTo(bx, by);
    const sw = (Math.random() - 0.5) * 7;
    fringeCtx.quadraticCurveTo(bx + sw * 0.6, by - bl * 0.5, bx + sw, by - bl);
    fringeCtx.stroke();
  }
  const fringeTex = new THREE.CanvasTexture(fringeTexCanvas);
  fringeTex.wrapS = fringeTex.wrapT = THREE.RepeatWrapping;
  fringeTex.repeat.set(6, 5);
  fringeTex.anisotropy = 8;
  const fringeGeo = new THREE.BoxGeometry(CW + 2.5, 0.18, CH + 2.5);
  const fringeMat = new THREE.MeshStandardMaterial({ color: 0x267840, roughness: 0.88, map: fringeTex });
  const fringe = new THREE.Mesh(fringeGeo, fringeMat);
  fringe.position.set(CW / 2, -0.16, CH / 2);
  fringe.receiveShadow = true;
  courseGroup.add(fringe);

  // Border walls with beveled top
  const bThick = 0.45;
  const borders = [
    { x: CW / 2, z: -bThick / 2, w: CW + bThick * 2, d: bThick },
    { x: CW / 2, z: CH + bThick / 2, w: CW + bThick * 2, d: bThick },
    { x: -bThick / 2, z: CH / 2, w: bThick, d: CH },
    { x: CW + bThick / 2, z: CH / 2, w: bThick, d: CH },
  ];
  borders.forEach(b => {
    const geo = new THREE.BoxGeometry(b.w, BORDER_H, b.d);
    const mesh = new THREE.Mesh(geo, borderMat);
    mesh.position.set(b.x, BORDER_H / 2, b.z);
    mesh.castShadow = true;
    mesh.receiveShadow = true;
    courseGroup.add(mesh);
    // Rounded top cap
    const capGeo = new THREE.BoxGeometry(b.w + 0.04, 0.08, b.d + 0.04);
    const capMesh = new THREE.Mesh(capGeo, borderTopMat);
    capMesh.position.set(b.x, BORDER_H + 0.04, b.z);
    capMesh.castShadow = true;
    courseGroup.add(capMesh);
  });

  // Corner posts
  const corners = [[-bThick / 2, -bThick / 2], [CW + bThick / 2, -bThick / 2],
                    [-bThick / 2, CH + bThick / 2], [CW + bThick / 2, CH + bThick / 2]];
  corners.forEach(([cx, cz]) => {
    const postGeo = new THREE.CylinderGeometry(0.18, 0.18, BORDER_H + 0.2, 12);
    const post = new THREE.Mesh(postGeo, borderTopMat);
    post.position.set(cx, (BORDER_H + 0.2) / 2, cz);
    post.castShadow = true;
    courseGroup.add(post);
    // Ball on top of post
    const bGeo = new THREE.SphereGeometry(0.14, 10, 10);
    const bMesh = new THREE.Mesh(bGeo, borderTopMat);
    bMesh.position.set(cx, BORDER_H + 0.3, cz);
    courseGroup.add(bMesh);
  });

  // Hole
  const holeGeo = new THREE.CylinderGeometry(HOLE_R, HOLE_R, 0.35, 32);
  const holeMesh = new THREE.Mesh(holeGeo, holeMat);
  holeMesh.position.set(courseData.hx, -0.12, courseData.hz);
  courseGroup.add(holeMesh);

  // Hole rim (wider, shiny chrome ring)
  const rimGeo = new THREE.TorusGeometry(HOLE_R + 0.03, 0.06, 16, 48);
  const rimMesh = new THREE.Mesh(rimGeo, holeRimMat);
  rimMesh.rotation.x = -Math.PI / 2;
  rimMesh.position.set(courseData.hx, 0.02, courseData.hz);
  courseGroup.add(rimMesh);
  // Dark center
  const innerRingGeo = new THREE.CircleGeometry(HOLE_R, 32);
  const innerRingMat = new THREE.MeshBasicMaterial({ color: 0x030303 });
  const innerRing = new THREE.Mesh(innerRingGeo, innerRingMat);
  innerRing.rotation.x = -Math.PI / 2;
  innerRing.position.set(courseData.hx, 0.008, courseData.hz);
  courseGroup.add(innerRing);

  // Flag pole — taller, shinier
  const poleGeo = new THREE.CylinderGeometry(0.025, 0.025, 3.5, 12);
  const pole = new THREE.Mesh(poleGeo, flagPoleMat);
  pole.position.set(courseData.hx, 1.75, courseData.hz);
  pole.castShadow = true;
  courseGroup.add(pole);
  // Pole ball tip
  const poleTipGeo = new THREE.SphereGeometry(0.05, 8, 8);
  const poleTip = new THREE.Mesh(poleTipGeo, flagPoleMat);
  poleTip.position.set(courseData.hx, 3.52, courseData.hz);
  courseGroup.add(poleTip);

  // Flag — slightly curved with more segments for animation
  const flagShape = new THREE.Shape();
  flagShape.moveTo(0, 0);
  flagShape.quadraticCurveTo(0.5, -0.1, 0.9, -0.3);
  flagShape.lineTo(0, -0.65);
  const flagGeo = new THREE.ShapeGeometry(flagShape, 8);
  const flag = new THREE.Mesh(flagGeo, flagMat);
  flag.position.set(courseData.hx, 3.45, courseData.hz - 0.01);
  flag.castShadow = true;
  courseGroup.add(flag);
  flagMeshRef = flag;

  // Hole glow ring (subtle green glow on ground around hole)
  const holeGlowGeo = new THREE.RingGeometry(HOLE_R + 0.05, HOLE_R + 0.5, 32);
  const holeGlowMat = new THREE.MeshBasicMaterial({
    color: 0x5dffd4, transparent: true, opacity: 0.12, depthWrite: false,
    side: THREE.DoubleSide,
  });
  const holeGlow = new THREE.Mesh(holeGlowGeo, holeGlowMat);
  holeGlow.rotation.x = -Math.PI / 2;
  holeGlow.position.set(courseData.hx, 0.01, courseData.hz);
  courseGroup.add(holeGlow);

  // Tee marker (colored stakes at start position)
  for (let side = -1; side <= 1; side += 2) {
    const teeGeo = new THREE.CylinderGeometry(0.04, 0.04, 0.25, 6);
    const teeMat = new THREE.MeshStandardMaterial({ color: 0xf5f5f5, roughness: 0.4 });
    const tee = new THREE.Mesh(teeGeo, teeMat);
    tee.position.set(courseData.bx + side * 0.6, 0.125, courseData.bz);
    courseGroup.add(tee);
    // Colored top
    const topGeo = new THREE.SphereGeometry(0.06, 6, 6);
    const topMat = new THREE.MeshStandardMaterial({ color: 0x4ecdc4, roughness: 0.3 });
    const top = new THREE.Mesh(topGeo, topMat);
    top.position.set(courseData.bx + side * 0.6, 0.26, courseData.bz);
    courseGroup.add(top);
  }

  // Obstacles
  courseData.obs.forEach(ob => {
    if (ob.type === 'rect') {
      const h = ob.h || 0.7;
      // Wood crate - main body
      const geo = new THREE.BoxGeometry(ob.w, h, ob.d);
      const mesh = new THREE.Mesh(geo, woodMat);
      mesh.position.set(ob.x, h / 2, ob.z);
      mesh.castShadow = true;
      mesh.receiveShadow = true;
      courseGroup.add(mesh);
      // Top highlight
      const topGeo = new THREE.BoxGeometry(ob.w + 0.02, 0.05, ob.d + 0.02);
      const topMesh = new THREE.Mesh(topGeo, woodTopMat);
      topMesh.position.set(ob.x, h + 0.025, ob.z);
      courseGroup.add(topMesh);
      // Bottom edge
      const baseGeo = new THREE.BoxGeometry(ob.w + 0.04, 0.06, ob.d + 0.04);
      const baseMat = new THREE.MeshStandardMaterial({ color: 0x6b4520, roughness: 0.8 });
      const baseMesh = new THREE.Mesh(baseGeo, baseMat);
      baseMesh.position.set(ob.x, 0.03, ob.z);
      courseGroup.add(baseMesh);
    } else {
      // Natural rock cluster
      const rockGroup = new THREE.Group();
      rockGroup.position.set(ob.x, 0, ob.z);
      const rng2 = mulberry32(Math.floor(ob.x * 100 + ob.z * 10));
      // Main rock - irregular
      const mainGeo = new THREE.DodecahedronGeometry(ob.r, 1);
      // Deform vertices for natural look
      const mainPos = mainGeo.attributes.position;
      for (let vi = 0; vi < mainPos.count; vi++) {
        const x = mainPos.getX(vi), y = mainPos.getY(vi), z = mainPos.getZ(vi);
        const noise = 1 + (Math.sin(x * 5 + z * 3) * 0.08 + Math.cos(y * 7) * 0.06);
        mainPos.setXYZ(vi, x * noise, y * noise, z * noise);
      }
      mainGeo.computeVertexNormals();
      const mainMesh = new THREE.Mesh(mainGeo, rockMat);
      mainMesh.position.y = ob.r * 0.5;
      mainMesh.scale.y = 0.55;
      mainMesh.rotation.y = rng2() * Math.PI;
      mainMesh.castShadow = true;
      mainMesh.receiveShadow = true;
      rockGroup.add(mainMesh);
      // 2-3 accent rocks
      const numAccent = 2 + (rng2() > 0.5 ? 1 : 0);
      for (let j = 0; j < numAccent; j++) {
        const sr = ob.r * (0.2 + rng2() * 0.2);
        const sGeo = new THREE.DodecahedronGeometry(sr, 0);
        const sMesh = new THREE.Mesh(sGeo, j === 0 ? rockDarkMat : rockMat);
        const ang = rng2() * Math.PI * 2;
        const dist2 = ob.r * (0.55 + rng2() * 0.3);
        sMesh.position.set(Math.cos(ang) * dist2, sr * 0.4, Math.sin(ang) * dist2);
        sMesh.scale.y = 0.45 + rng2() * 0.3;
        sMesh.rotation.set(rng2() * 0.5, rng2() * Math.PI, rng2() * 0.3);
        sMesh.castShadow = true;
        rockGroup.add(sMesh);
      }
      // Moss patch on main rock
      const mossGeo = new THREE.SphereGeometry(ob.r * 0.4, 6, 4);
      const moss = new THREE.Mesh(mossGeo, rockMossMat);
      moss.position.set(ob.r * 0.2, ob.r * 0.35, ob.r * 0.2);
      moss.scale.set(1, 0.2, 1);
      rockGroup.add(moss);
      courseGroup.add(rockGroup);
    }
  });

  // Walls - with cap and posts
  courseData.walls.forEach(w => {
    const dx = w.x2 - w.x1, dz = w.z2 - w.z1;
    const len = Math.sqrt(dx * dx + dz * dz);
    const angle = Math.atan2(dz, dx);
    const wallH = 0.6;
    const wallThick = 0.25;
    const midX = (w.x1 + w.x2) / 2, midZ = (w.z1 + w.z2) / 2;
    // Main wall body
    const geo = new THREE.BoxGeometry(len, wallH, wallThick);
    const mesh = new THREE.Mesh(geo, wallMat);
    mesh.position.set(midX, wallH / 2, midZ);
    mesh.rotation.y = -angle;
    mesh.castShadow = true;
    mesh.receiveShadow = true;
    courseGroup.add(mesh);
    // Wall top cap
    const capGeo = new THREE.BoxGeometry(len + 0.06, 0.06, wallThick + 0.06);
    const capMesh = new THREE.Mesh(capGeo, wallCapMat);
    capMesh.position.set(midX, wallH + 0.03, midZ);
    capMesh.rotation.y = -angle;
    capMesh.castShadow = true;
    courseGroup.add(capMesh);
    // End posts
    [w.x1, w.x2].forEach((px, idx) => {
      const pz = idx === 0 ? w.z1 : w.z2;
      const postGeo = new THREE.CylinderGeometry(0.08, 0.08, wallH + 0.15, 8);
      const post = new THREE.Mesh(postGeo, wallCapMat);
      post.position.set(px, (wallH + 0.15) / 2, pz);
      post.castShadow = true;
      courseGroup.add(post);
    });
  });

  // Decorative trees — varied types (more trees for lush scenery)
  const rng = mulberry32(courseData.bx * 1000 + courseData.hz * 100);
  for (let i = 0; i < 45; i++) {
    const tx = -20 + rng() * (CW + 40);
    const tz = -20 + rng() * (CH + 40);
    if (tx > -2 && tx < CW + 2 && tz > -2 && tz < CH + 2) continue;

    const treeType = rng();
    if (treeType < 0.4) {
      // Pine tree
      const trunkH = 1.2 + rng() * 0.8;
      const trunkGeo = new THREE.CylinderGeometry(0.1, 0.18, trunkH, 6);
      const trunkMat2 = new THREE.MeshStandardMaterial({ color: 0x6b4520, roughness: 0.9 });
      const trunk = new THREE.Mesh(trunkGeo, trunkMat2);
      trunk.position.set(tx, trunkH / 2, tz);
      trunk.castShadow = true;
      courseGroup.add(trunk);
      // 3 stacked cone layers
      for (let layer = 0; layer < 3; layer++) {
        const lr = 1.3 - layer * 0.3;
        const lh = 1.6 - layer * 0.2;
        const lGeo = new THREE.ConeGeometry(lr, lh, 8);
        const shade = 0x1e6b30 + layer * 0x081008;
        const lMat = new THREE.MeshStandardMaterial({ color: shade, roughness: 0.85 });
        const lMesh = new THREE.Mesh(lGeo, lMat);
        lMesh.position.set(tx, trunkH + 0.4 + layer * 0.7, tz);
        lMesh.castShadow = true;
        courseGroup.add(lMesh);
      }
    } else if (treeType < 0.7) {
      // Round tree
      const trunkH = 1.0 + rng() * 0.6;
      const trunkGeo = new THREE.CylinderGeometry(0.12, 0.16, trunkH, 6);
      const trunkMat2 = new THREE.MeshStandardMaterial({ color: 0x7a5530, roughness: 0.85 });
      const trunk = new THREE.Mesh(trunkGeo, trunkMat2);
      trunk.position.set(tx, trunkH / 2, tz);
      trunk.castShadow = true;
      courseGroup.add(trunk);
      // Round canopy (multiple spheres for fluffiness)
      const canopyR = 1.0 + rng() * 0.5;
      for (let c = 0; c < 4; c++) {
        const cr = canopyR * (0.5 + rng() * 0.35);
        const ca = rng() * Math.PI * 2;
        const coff = c === 0 ? 0 : canopyR * 0.3;
        const sGeo = new THREE.SphereGeometry(cr, 10, 8);
        const sMat = new THREE.MeshStandardMaterial({
          color: new THREE.Color().setHSL(0.28 + rng() * 0.06, 0.5 + rng() * 0.2, 0.3 + rng() * 0.1),
          roughness: 0.85
        });
        const sMesh = new THREE.Mesh(sGeo, sMat);
        sMesh.position.set(tx + Math.cos(ca) * coff, trunkH + canopyR * 0.6, tz + Math.sin(ca) * coff);
        sMesh.castShadow = true;
        courseGroup.add(sMesh);
      }
    } else {
      // Bush (no trunk, small)
      const bushN = 2 + Math.floor(rng() * 3);
      for (let b = 0; b < bushN; b++) {
        const br = 0.4 + rng() * 0.5;
        const ba = rng() * Math.PI * 2;
        const geoB = new THREE.SphereGeometry(br, 8, 6);
        const matB = new THREE.MeshStandardMaterial({
          color: new THREE.Color().setHSL(0.25 + rng() * 0.08, 0.45 + rng() * 0.2, 0.28 + rng() * 0.12),
          roughness: 0.9
        });
        const meshB = new THREE.Mesh(geoB, matB);
        meshB.position.set(tx + Math.cos(ba) * 0.3, br * 0.65, tz + Math.sin(ba) * 0.3);
        meshB.scale.y = 0.7;
        meshB.castShadow = true;
        courseGroup.add(meshB);
      }
    }
  }

  // Flowers scattered near course
  for (let i = 0; i < 30; i++) {
    const fx = -5 + rng() * (CW + 10);
    const fz = -5 + rng() * (CH + 10);
    if (fx > -0.5 && fx < CW + 0.5 && fz > -0.5 && fz < CH + 0.5) continue;
    const flowerColors = [0xff6b6b, 0xffd93d, 0xc792ea, 0xff8a5c, 0x48dbfb, 0xff9ff3];
    const fColor = flowerColors[Math.floor(rng() * flowerColors.length)];
    // Flower head
    const fGeo = new THREE.SphereGeometry(0.08 + rng() * 0.06, 6, 6);
    const fMat = new THREE.MeshStandardMaterial({ color: fColor, roughness: 0.7 });
    const flower = new THREE.Mesh(fGeo, fMat);
    flower.position.set(fx, 0.12 + rng() * 0.08, fz);
    courseGroup.add(flower);
    // Stem
    const stemGeo = new THREE.CylinderGeometry(0.01, 0.015, 0.15, 4);
    const stemMat = new THREE.MeshStandardMaterial({ color: 0x2d6b30, roughness: 0.9 });
    const stem = new THREE.Mesh(stemGeo, stemMat);
    stem.position.set(fx, 0.06, fz);
    courseGroup.add(stem);
  }

  // Sand patches near some obstacles (decorative)
  courseData.obs.forEach((ob, idx) => {
    if (idx % 3 !== 0) return;
    const sx = ob.x + (ob.type === 'rect' ? ob.w * 0.6 : ob.r * 1.2);
    const sz = ob.z;
    if (sx < 1 || sx > CW - 1 || sz < 1 || sz > CH - 1) return;
    const sandGeo = new THREE.CircleGeometry(0.6 + Math.random() * 0.4, 12);
    const sand = new THREE.Mesh(sandGeo, sandMat);
    sand.rotation.x = -Math.PI / 2;
    sand.position.set(sx, 0.006, sz);
    courseGroup.add(sand);
  });

  // ---- On-course extras ----

  // Stepping stone path (decorative flat stones across part of course)
  {
    const pathStartX = 2 + rng() * 8;
    const pathStartZ = CH * 0.3 + rng() * CH * 0.4;
    const pathAngle = rng() * 0.6 - 0.3;
    const numStones = 4 + Math.floor(rng() * 4);
    for (let s = 0; s < numStones; s++) {
      const stoneX = pathStartX + s * (1.6 + rng() * 0.6) * Math.cos(pathAngle);
      const stoneZ = pathStartZ + s * (1.6 + rng() * 0.6) * Math.sin(pathAngle) + (rng() - 0.5) * 0.4;
      if (stoneX < 0.5 || stoneX > CW - 0.5 || stoneZ < 0.5 || stoneZ > CH - 0.5) continue;
      const sR = 0.2 + rng() * 0.15;
      const stoneGeo = new THREE.CylinderGeometry(sR, sR + 0.03, 0.06, 7 + Math.floor(rng() * 4));
      const shade = 0.55 + rng() * 0.2;
      const stoneMat2 = new THREE.MeshStandardMaterial({
        color: new THREE.Color(shade, shade, shade * 0.95), roughness: 0.85,
      });
      const stone = new THREE.Mesh(stoneGeo, stoneMat2);
      stone.position.set(stoneX, 0.03, stoneZ);
      stone.rotation.y = rng() * Math.PI;
      stone.receiveShadow = true;
      courseGroup.add(stone);
    }
  }

  // Small garden patch (flower bed on-course)
  {
    const gpx = CW * 0.3 + rng() * CW * 0.4;
    const gpz = 2 + rng() * 4;
    // Low stone border
    const gardenR = 0.8 + rng() * 0.6;
    const borderGeo2 = new THREE.TorusGeometry(gardenR, 0.06, 6, 20);
    const borderMat3 = new THREE.MeshStandardMaterial({ color: 0x888880, roughness: 0.8 });
    const borderMesh2 = new THREE.Mesh(borderGeo2, borderMat3);
    borderMesh2.rotation.x = -Math.PI / 2;
    borderMesh2.position.set(gpx, 0.06, gpz);
    courseGroup.add(borderMesh2);
    // Soil
    const soilGeo = new THREE.CircleGeometry(gardenR - 0.05, 20);
    const soilMat = new THREE.MeshStandardMaterial({ color: 0x5a3a20, roughness: 0.95 });
    const soil = new THREE.Mesh(soilGeo, soilMat);
    soil.rotation.x = -Math.PI / 2;
    soil.position.set(gpx, 0.008, gpz);
    courseGroup.add(soil);
    // Mini flowers
    const miniColors = [0xff4466, 0xffaa33, 0xff66aa, 0xffdd44, 0xaa44ff];
    for (let mf = 0; mf < 6 + Math.floor(rng() * 5); mf++) {
      const ma = rng() * Math.PI * 2;
      const md = rng() * (gardenR - 0.2);
      const mGeo = new THREE.SphereGeometry(0.04 + rng() * 0.03, 5, 5);
      const mMat = new THREE.MeshStandardMaterial({
        color: miniColors[Math.floor(rng() * miniColors.length)], roughness: 0.6,
      });
      const mMesh = new THREE.Mesh(mGeo, mMat);
      mMesh.position.set(gpx + Math.cos(ma) * md, 0.04 + rng() * 0.04, gpz + Math.sin(ma) * md);
      courseGroup.add(mMesh);
    }
  }

  // Mushrooms (2-4 small clusters on the course)
  for (let mi = 0; mi < 2 + Math.floor(rng() * 3); mi++) {
    const mx = 2 + rng() * (CW - 4);
    const mz = 2 + rng() * (CH - 4);
    // Skip if too close to ball start, hole, or an obstacle
    if (dist(mx, mz, courseData.bx, courseData.bz) < 2.5) continue;
    if (dist(mx, mz, courseData.hx, courseData.hz) < 2.5) continue;
    const numMush = 1 + Math.floor(rng() * 3);
    for (let m = 0; m < numMush; m++) {
      const offX = (rng() - 0.5) * 0.5;
      const offZ = (rng() - 0.5) * 0.5;
      const mh = 0.1 + rng() * 0.12;
      const mr = 0.06 + rng() * 0.06;
      // Stem
      const stemGeo2 = new THREE.CylinderGeometry(mr * 0.35, mr * 0.45, mh, 6);
      const stemMat2 = new THREE.MeshStandardMaterial({ color: 0xf0e8d8, roughness: 0.8 });
      const stem = new THREE.Mesh(stemGeo2, stemMat2);
      stem.position.set(mx + offX, mh / 2, mz + offZ);
      courseGroup.add(stem);
      // Cap
      const isRed = rng() > 0.5;
      const capGeo = new THREE.SphereGeometry(mr, 8, 6, 0, Math.PI * 2, 0, Math.PI / 2);
      const capMat = new THREE.MeshStandardMaterial({
        color: isRed ? 0xcc2222 : 0xc8a050, roughness: 0.6,
      });
      const cap = new THREE.Mesh(capGeo, capMat);
      cap.position.set(mx + offX, mh, mz + offZ);
      courseGroup.add(cap);
      // White dots on red mushrooms
      if (isRed) {
        for (let wd = 0; wd < 3; wd++) {
          const da = rng() * Math.PI * 2;
          const dotGeo = new THREE.SphereGeometry(0.012, 4, 4);
          const dotMat = new THREE.MeshBasicMaterial({ color: 0xffffff });
          const dotM = new THREE.Mesh(dotGeo, dotMat);
          dotM.position.set(
            mx + offX + Math.cos(da) * mr * 0.6,
            mh + 0.01,
            mz + offZ + Math.sin(da) * mr * 0.6
          );
          courseGroup.add(dotM);
        }
      }
    }
  }

  // Wooden bench (scenic, on edge of course)
  {
    const benchSide = rng() > 0.5;
    const benchX = benchSide ? CW - 0.3 : 0.3;
    const benchZ = 5 + rng() * (CH - 10);
    const benchGroup2 = new THREE.Group();
    // Seat
    const seatGeo = new THREE.BoxGeometry(0.6, 0.06, 1.2);
    const benchWood = new THREE.MeshStandardMaterial({ color: 0x8b6b42, roughness: 0.7 });
    const seat = new THREE.Mesh(seatGeo, benchWood);
    seat.position.y = 0.35;
    benchGroup2.add(seat);
    // Back
    const backGeo = new THREE.BoxGeometry(0.06, 0.35, 1.1);
    const back = new THREE.Mesh(backGeo, benchWood);
    back.position.set(benchSide ? -0.25 : 0.25, 0.5, 0);
    benchGroup2.add(back);
    // Legs
    for (let lz = -0.45; lz <= 0.45; lz += 0.9) {
      const legGeo = new THREE.BoxGeometry(0.06, 0.35, 0.06);
      const leg = new THREE.Mesh(legGeo, benchWood);
      leg.position.set(0, 0.175, lz);
      benchGroup2.add(leg);
    }
    benchGroup2.position.set(benchX, 0, benchZ);
    benchGroup2.castShadow = true;
    courseGroup.add(benchGroup2);
  }

  // Small wooden bridge over a decorative ditch
  {
    const bridgeX = CW * 0.4 + rng() * CW * 0.2;
    const bridgeZ = CH * 0.35 + rng() * CH * 0.3;
    const bridgeLen = 2.5;
    const bridgeW = 1.0;
    // Ditch (dark depression)
    const ditchGeo = new THREE.BoxGeometry(bridgeW + 0.4, 0.15, bridgeLen + 0.6);
    const ditchMat = new THREE.MeshStandardMaterial({ color: 0x1a3a28, roughness: 0.95 });
    const ditch = new THREE.Mesh(ditchGeo, ditchMat);
    ditch.position.set(bridgeX, -0.08, bridgeZ);
    courseGroup.add(ditch);
    // Bridge planks
    const bridgeWood = new THREE.MeshStandardMaterial({ color: 0x9a7045, roughness: 0.65 });
    for (let p = -4; p <= 4; p++) {
      const plankGeo = new THREE.BoxGeometry(bridgeW * 0.95, 0.05, 0.22);
      const plank = new THREE.Mesh(plankGeo, bridgeWood);
      plank.position.set(bridgeX, 0.035, bridgeZ + p * 0.28);
      plank.castShadow = true;
      courseGroup.add(plank);
    }
    // Railings
    for (let side = -1; side <= 1; side += 2) {
      // Posts
      for (let pz = -1; pz <= 1; pz += 2) {
        const postGeo2 = new THREE.CylinderGeometry(0.03, 0.03, 0.4, 6);
        const post = new THREE.Mesh(postGeo2, bridgeWood);
        post.position.set(bridgeX + side * bridgeW * 0.45, 0.25, bridgeZ + pz * bridgeLen * 0.4);
        courseGroup.add(post);
      }
      // Rail
      const railGeo = new THREE.CylinderGeometry(0.02, 0.02, bridgeLen * 0.85, 6);
      const rail = new THREE.Mesh(railGeo, bridgeWood);
      rail.rotation.x = Math.PI / 2;
      rail.position.set(bridgeX + side * bridgeW * 0.45, 0.42, bridgeZ);
      courseGroup.add(rail);
    }
  }

  // ---- Ponds with fish (2-3 ponds at scenic locations) ----
  const pondPositions = [
    { x: -5 + rng() * 4, z: 5 + rng() * (CH - 10), r: 2.0 + rng() * 1.5 },
    { x: CW + 2 + rng() * 4, z: 4 + rng() * (CH - 8), r: 1.5 + rng() * 1.2 },
  ];
  // 50% chance of a third smaller pond
  if (rng() > 0.5) {
    const side = rng() > 0.5 ? -6 : CW + 3;
    pondPositions.push({ x: side + rng() * 3, z: CH * 0.3 + rng() * CH * 0.4, r: 1.2 + rng() * 0.8 });
  }

  pondPositions.forEach((pond, pondIdx) => {
    const pondX = pond.x, pondZ = pond.z, pondR = pond.r;

    // Pond bed (dark bottom)
    const bedGeo = new THREE.CircleGeometry(pondR + 0.2, 28);
    const bedMat2 = new THREE.MeshStandardMaterial({ color: 0x14384e, roughness: 0.95 });
    const bed = new THREE.Mesh(bedGeo, bedMat2);
    bed.rotation.x = -Math.PI / 2;
    bed.position.set(pondX, -0.05, pondZ);
    courseGroup.add(bed);

    // Sandy bank ring
    const bankGeo = new THREE.RingGeometry(pondR - 0.05, pondR + 0.4, 28);
    const bankMat2 = new THREE.MeshStandardMaterial({ color: 0xc4ad7a, roughness: 0.9 });
    const bank = new THREE.Mesh(bankGeo, bankMat2);
    bank.rotation.x = -Math.PI / 2;
    bank.position.set(pondX, -0.02, pondZ);
    courseGroup.add(bank);

    // Water surface
    const waterGeo = new THREE.CircleGeometry(pondR - 0.1, 28);
    const waterClone = waterMat.clone(); // each pond gets own material for independent animation
    const water = new THREE.Mesh(waterGeo, waterClone);
    water.rotation.x = -Math.PI / 2;
    water.position.set(pondX, 0.0, pondZ);
    courseGroup.add(water);
    waterMeshRefs.push(water);

    // Lily pads
    const numLilies = 2 + Math.floor(rng() * 3);
    for (let lp = 0; lp < numLilies; lp++) {
      const la = rng() * Math.PI * 2;
      const ld = pondR * 0.2 + rng() * pondR * 0.5;
      const lilyR = 0.15 + rng() * 0.14;
      // Lily pad with notch (pie slice shape)
      const lilyShape = new THREE.Shape();
      const segments = 20;
      for (let s = 0; s <= segments; s++) {
        const a = (s / segments) * Math.PI * 1.85 + 0.15;
        const x = Math.cos(a) * lilyR;
        const y = Math.sin(a) * lilyR;
        if (s === 0) lilyShape.moveTo(x, y);
        else lilyShape.lineTo(x, y);
      }
      lilyShape.lineTo(0, 0);
      const lilyGeo = new THREE.ShapeGeometry(lilyShape);
      const shade = rng() > 0.5 ? 0x2d8838 : 0x358540;
      const lilyMat2 = new THREE.MeshStandardMaterial({ color: shade, roughness: 0.65, side: THREE.DoubleSide });
      const lily = new THREE.Mesh(lilyGeo, lilyMat2);
      lily.rotation.x = -Math.PI / 2;
      lily.rotation.z = rng() * Math.PI * 2;
      lily.position.set(pondX + Math.cos(la) * ld, 0.012, pondZ + Math.sin(la) * ld);
      courseGroup.add(lily);
      // Flower on some lily pads
      if (rng() > 0.5) {
        const petalColors = [0xffb7c5, 0xffffff, 0xfff0b0];
        const pc = petalColors[Math.floor(rng() * petalColors.length)];
        const flGeo = new THREE.SphereGeometry(0.05, 6, 6);
        const flMat2 = new THREE.MeshStandardMaterial({ color: pc, roughness: 0.5 });
        const fl = new THREE.Mesh(flGeo, flMat2);
        fl.position.set(pondX + Math.cos(la) * ld, 0.05, pondZ + Math.sin(la) * ld);
        fl.scale.y = 0.5;
        courseGroup.add(fl);
      }
    }

    // Reeds and cattails around pond
    const numReeds = 4 + Math.floor(rng() * 4);
    for (let r = 0; r < numReeds; r++) {
      const ra = rng() * Math.PI * 2;
      const rd = pondR * (0.85 + rng() * 0.3);
      const reedH = 0.5 + rng() * 0.7;
      const reedGeo = new THREE.CylinderGeometry(0.012, 0.022, reedH, 4);
      const reedMat2 = new THREE.MeshStandardMaterial({ color: 0x4a7a35, roughness: 0.9 });
      const reed = new THREE.Mesh(reedGeo, reedMat2);
      const rx = pondX + Math.cos(ra) * rd;
      const rz = pondZ + Math.sin(ra) * rd;
      reed.position.set(rx, reedH / 2, rz);
      reed.rotation.z = (rng() - 0.5) * 0.15;
      courseGroup.add(reed);
      // Cattail head on some reeds
      if (rng() > 0.4) {
        const catGeo = new THREE.CylinderGeometry(0.03, 0.035, 0.12, 6);
        const catMat2 = new THREE.MeshStandardMaterial({ color: 0x5c3a1a, roughness: 0.95 });
        const cat = new THREE.Mesh(catGeo, catMat2);
        cat.position.set(rx, reedH + 0.04, rz);
        courseGroup.add(cat);
      }
    }

    // Small rocks at pond edge
    for (let sr = 0; sr < 3; sr++) {
      const sra = rng() * Math.PI * 2;
      const srd = pondR * (0.9 + rng() * 0.2);
      const stoneR = 0.08 + rng() * 0.12;
      const stoneGeo = new THREE.DodecahedronGeometry(stoneR, 0);
      const stoneMat2 = new THREE.MeshStandardMaterial({ color: 0x808080, roughness: 0.9 });
      const stone = new THREE.Mesh(stoneGeo, stoneMat2);
      stone.position.set(pondX + Math.cos(sra) * srd, stoneR * 0.3, pondZ + Math.sin(sra) * srd);
      stone.scale.y = 0.5;
      courseGroup.add(stone);
    }

    // ---- Fish in each pond ----
    const numFish = 2 + Math.floor(rng() * 2); // 2-3 fish per pond
    for (let fi = 0; fi < numFish; fi++) {
      const fishGroup = new THREE.Group();

      // Fish colors — koi-inspired
      const fishColors = [0xff6633, 0xe8c840, 0xff4444, 0xffa020, 0xcc3300];
      const fColor = fishColors[Math.floor(rng() * fishColors.length)];
      const fishMat2 = new THREE.MeshPhysicalMaterial({
        color: fColor, roughness: 0.2, metalness: 0.3, clearcoat: 0.8,
      });

      // Body — tapered ellipsoid
      const bodyGeo = new THREE.SphereGeometry(0.12, 10, 8);
      const body = new THREE.Mesh(bodyGeo, fishMat2);
      body.scale.set(1.8, 0.7, 1);
      fishGroup.add(body);

      // White belly
      const bellyGeo = new THREE.SphereGeometry(0.1, 8, 6);
      const bellyMat2 = new THREE.MeshStandardMaterial({ color: 0xfff8ee, roughness: 0.3 });
      const belly = new THREE.Mesh(bellyGeo, bellyMat2);
      belly.scale.set(1.5, 0.4, 0.8);
      belly.position.y = -0.03;
      fishGroup.add(belly);

      // Tail fin
      const tailShape = new THREE.Shape();
      tailShape.moveTo(0, 0);
      tailShape.quadraticCurveTo(-0.08, 0.06, -0.15, 0.1);
      tailShape.lineTo(-0.12, 0);
      tailShape.lineTo(-0.15, -0.1);
      tailShape.quadraticCurveTo(-0.08, -0.06, 0, 0);
      const tailGeo = new THREE.ShapeGeometry(tailShape);
      const tailMat2 = new THREE.MeshStandardMaterial({ color: fColor, roughness: 0.3, side: THREE.DoubleSide });
      const tail = new THREE.Mesh(tailGeo, tailMat2);
      tail.position.set(-0.2, 0, 0);
      tail.rotation.y = Math.PI / 2;
      fishGroup.add(tail);

      // Dorsal fin
      const dorsalShape = new THREE.Shape();
      dorsalShape.moveTo(-0.05, 0);
      dorsalShape.quadraticCurveTo(0, 0.06, 0.08, 0);
      const dorsalGeo = new THREE.ShapeGeometry(dorsalShape);
      const dorsal = new THREE.Mesh(dorsalGeo, tailMat2);
      dorsal.position.set(0.02, 0.07, 0);
      fishGroup.add(dorsal);

      // Eyes
      for (let side = -1; side <= 1; side += 2) {
        const eyeGeo = new THREE.SphereGeometry(0.015, 6, 6);
        const eyeMat2 = new THREE.MeshBasicMaterial({ color: 0x111111 });
        const eye = new THREE.Mesh(eyeGeo, eyeMat2);
        eye.position.set(0.16, 0.01, side * 0.06);
        fishGroup.add(eye);
      }

      // Position fish in pond
      const fAngle = rng() * Math.PI * 2;
      const fDist = rng() * pondR * 0.5;
      fishGroup.position.set(
        pondX + Math.cos(fAngle) * fDist,
        -0.02,
        pondZ + Math.sin(fAngle) * fDist
      );
      fishGroup.rotation.y = fAngle;
      fishGroup.scale.setScalar(0.7 + rng() * 0.4);
      scene.add(fishGroup);

      // Fish animation data
      fishList.push({
        mesh: fishGroup,
        tail: tail,
        pondX, pondZ, pondR,
        angle: fAngle,
        speed: 0.3 + rng() * 0.4,
        swimRadius: pondR * (0.2 + rng() * 0.4),
        phaseOffset: rng() * Math.PI * 2,
        jumpTime: -1,
        jumpInterval: 3 + rng() * 5, // seconds between jumps
        lastJump: rng() * -5, // stagger first jumps
        jumpDuration: 0.9 + rng() * 0.4,
        jumpHeight: 0.7 + rng() * 0.5,
      });
    }
  });

  // Create splash particle pool
  for (let sp = 0; sp < 15; sp++) {
    const spGeo = new THREE.SphereGeometry(0.025, 4, 4);
    const spMat2 = new THREE.MeshBasicMaterial({
      color: 0xcceeff, transparent: true, opacity: 0.7, depthWrite: false
    });
    const spMesh = new THREE.Mesh(spGeo, spMat2);
    spMesh.visible = false;
    scene.add(spMesh);
    splashParticles.push({
      mesh: spMesh, active: false,
      vx: 0, vy: 0, vz: 0, life: 0,
    });
  }

  // ---- Build Secret Objects ----
  // Clean old secret meshes
  if (secretMesh) { courseGroup.remove(secretMesh); secretMesh = null; }
  secretTargetMeshes.forEach(m => courseGroup.remove(m));
  secretTargetMeshes = [];

  if (secretData) {
    // Crystal — glowing floating gem
    const crystalGeo = new THREE.OctahedronGeometry(0.25, 0);
    const crystalMat = new THREE.MeshPhysicalMaterial({
      color: secretData.type === 'simple' ? 0x8844ff : 0x6622cc,
      roughness: 0.05, metalness: 0.3, clearcoat: 1.0,
      transparent: true, opacity: secretData.type === 'simple' ? 0.7 : 0.3,
      emissive: 0x6622cc, emissiveIntensity: 0.5,
    });
    secretMesh = new THREE.Mesh(crystalGeo, crystalMat);
    secretMesh.position.set(secretData.crystal.x, 0.35, secretData.crystal.z);
    secretMesh.castShadow = true;
    courseGroup.add(secretMesh);

    // Glow ring underneath crystal
    const glowGeo = new THREE.RingGeometry(0.15, 0.6, 24);
    const glowMat = new THREE.MeshBasicMaterial({
      color: 0xaa66ff, transparent: true, opacity: 0.15, depthWrite: false, side: THREE.DoubleSide,
    });
    const glow = new THREE.Mesh(glowGeo, glowMat);
    glow.rotation.x = -Math.PI / 2;
    glow.position.set(secretData.crystal.x, 0.01, secretData.crystal.z);
    courseGroup.add(glow);

    // Pattern targets (rune stones) for hard levels
    if (secretData.type === 'pattern') {
      secretData.targets.forEach((tgt, idx) => {
        // Rune stone — small pillar with glyph
        const runeGroup = new THREE.Group();
        // Stone base
        const stoneGeo = new THREE.CylinderGeometry(0.25, 0.3, 0.15, 6);
        const stoneMat = new THREE.MeshStandardMaterial({
          color: 0x555566, roughness: 0.7, metalness: 0.1,
        });
        const stone = new THREE.Mesh(stoneGeo, stoneMat);
        stone.position.y = 0.075;
        runeGroup.add(stone);
        // Glyph ring on top
        const ringGeo = new THREE.TorusGeometry(0.18, 0.025, 6, 16);
        const ringMat = new THREE.MeshBasicMaterial({
          color: 0xaa66ff, transparent: true, opacity: 0.4 + idx * 0.15,
        });
        const ring = new THREE.Mesh(ringGeo, ringMat);
        ring.rotation.x = -Math.PI / 2;
        ring.position.y = 0.16;
        runeGroup.add(ring);
        // Number indicator (dots)
        for (let d = 0; d <= idx; d++) {
          const dotGeo = new THREE.SphereGeometry(0.03, 6, 6);
          const dotMat = new THREE.MeshBasicMaterial({ color: 0xcc88ff });
          const dot = new THREE.Mesh(dotGeo, dotMat);
          const da = (d / (idx + 1)) * Math.PI * 2;
          dot.position.set(Math.cos(da) * 0.1, 0.2, Math.sin(da) * 0.1);
          runeGroup.add(dot);
        }
        runeGroup.position.set(tgt.x, 0, tgt.z);
        courseGroup.add(runeGroup);
        secretTargetMeshes.push(runeGroup);
      });
    }
  }

  // ---- Sparkle Lights (collectible gems aligned on a hidden line) ----
  // Clean old
  sparkleLights.forEach(sl => { if (sl.mesh) courseGroup.remove(sl.mesh); });
  sparkleLights = [];
  lightsCollectedThisStroke = 0;
  // Difficulty scales with tournament progress (overall level = tournamentIndex * 3 + holeIndex)
  const sparkleLevel = tournamentIndex * holesPerTournament + holeIndex;
  // Generate sparkle lights — count and spacing scale with difficulty
  const sparkleColors = [
    { gem: 0x44ddff, glow: 0x22aadd, name: 'Aqua' },
    { gem: 0xff88cc, glow: 0xdd66aa, name: 'Rose' },
    { gem: 0xffdd44, glow: 0xddbb22, name: 'Gold' },
    { gem: 0x88ff66, glow: 0x66dd44, name: 'Jade' },
    { gem: 0xffaa44, glow: 0xdd8822, name: 'Amber' },
    { gem: 0xcc88ff, glow: 0xaa66dd, name: 'Violet' },
  ];
  // Easy (levels 0-2): 3 lights, close + bunched → any moderate hit works
  // Medium (levels 3-5): 4-5 lights, moderate spread → need decent aim + force
  // Hard (levels 6+): 5-7 lights, spread out → precise force control required
  let numSparkles, sparkleSpacing, sparkleStartDist, sparkleCollectRadius;
  if (sparkleLevel <= 2) {
    // Easy: few, bunched together, large pickup radius, close to ball
    numSparkles = 3;
    sparkleSpacing = 1.0 + rng() * 0.5;          // 1.0-1.5 apart
    sparkleStartDist = 2.0 + rng() * 1.0;         // start 2-3 from ball
    sparkleCollectRadius = BALL_R + 0.6;           // generous pickup
  } else if (sparkleLevel <= 5) {
    // Medium: more lights, moderate spacing
    numSparkles = 4 + Math.floor(rng() * 2);      // 4-5
    sparkleSpacing = 1.5 + rng() * 0.8;           // 1.5-2.3 apart
    sparkleStartDist = 2.5 + rng() * 1.5;         // start 2.5-4 from ball
    sparkleCollectRadius = BALL_R + 0.4;           // normal pickup
  } else {
    // Hard: many lights, spread out, precise force needed
    numSparkles = 5 + Math.floor(rng() * 3);      // 5-7
    sparkleSpacing = 2.0 + rng() * 1.5;           // 2.0-3.5 apart
    sparkleStartDist = 3.5 + rng() * 2.0;         // start 3.5-5.5 from ball
    sparkleCollectRadius = BALL_R + 0.3;           // tight pickup
  }
  // Pick a one-shot angle from the ball start position
  // Try multiple angles to find one where all lights fit on the course
  let oneShotAngle, oneShotDx, oneShotDz;
  let bestAngle = rng() * Math.PI * 2;
  let bestCount = 0;
  for (let attempt = 0; attempt < 12; attempt++) {
    const tryAngle = rng() * Math.PI * 2;
    const tdx = Math.cos(tryAngle);
    const tdz = Math.sin(tryAngle);
    let count = 0;
    for (let si = 0; si < numSparkles; si++) {
      const d = sparkleStartDist + si * sparkleSpacing;
      const px = courseData.bx + tdx * d;
      const pz = courseData.bz + tdz * d;
      if (px >= 1.5 && px <= CW - 1.5 && pz >= 1.5 && pz <= CH - 1.5) count++;
      else break;
    }
    if (count > bestCount) { bestCount = count; bestAngle = tryAngle; }
    if (count >= numSparkles) break;
  }
  oneShotAngle = bestAngle;
  oneShotDx = Math.cos(oneShotAngle);
  oneShotDz = Math.sin(oneShotAngle);

  for (let si = 0; si < numSparkles; si++) {
    const d = sparkleStartDist + si * sparkleSpacing;
    const sx = courseData.bx + oneShotDx * d;
    const sz = courseData.bz + oneShotDz * d;
    // Skip if out of bounds
    if (sx < 1.5 || sx > CW - 1.5 || sz < 1.5 || sz > CH - 1.5) continue;

    const colorSet = sparkleColors[Math.floor(rng() * sparkleColors.length)];
    const reward = 3 + Math.floor(rng() * 6); // 3-8 coins
    const gemSize = sparkleLevel <= 2 ? 0.18 : sparkleLevel <= 5 ? 0.14 : 0.10;
    const haloSize = sparkleLevel <= 2 ? 0.4 : sparkleLevel <= 5 ? 0.3 : 0.22;

    const sparkleGroup = new THREE.Group();
    // Small gem (diamond shape)
    const gemGeo = new THREE.OctahedronGeometry(gemSize, 0);
    const gemMat = new THREE.MeshPhysicalMaterial({
      color: colorSet.gem, roughness: 0.05, metalness: 0.4,
      clearcoat: 1.0, transparent: true, opacity: 0.85,
      emissive: colorSet.glow, emissiveIntensity: 0.6,
    });
    const gemMesh = new THREE.Mesh(gemGeo, gemMat);
    sparkleGroup.add(gemMesh);

    // Glow halo beneath
    const haloGeo = new THREE.RingGeometry(0.05, haloSize, 16);
    const haloMat = new THREE.MeshBasicMaterial({
      color: colorSet.glow, transparent: true, opacity: 0.12,
      depthWrite: false, side: THREE.DoubleSide, blending: THREE.AdditiveBlending,
    });
    const haloMesh = new THREE.Mesh(haloGeo, haloMat);
    haloMesh.rotation.x = -Math.PI / 2;
    haloMesh.position.y = -0.15;
    sparkleGroup.add(haloMesh);

    // Tiny orbiting point lights (2 small dots)
    for (let oi = 0; oi < 2; oi++) {
      const orbGeo = new THREE.SphereGeometry(0.02, 4, 4);
      const orbMat = new THREE.MeshBasicMaterial({
        color: 0xffffff, transparent: true, opacity: 0.7,
        blending: THREE.AdditiveBlending, depthWrite: false,
      });
      const orbMesh = new THREE.Mesh(orbGeo, orbMat);
      orbMesh.userData.orbitPhase = oi * Math.PI;
      sparkleGroup.add(orbMesh);
    }

    sparkleGroup.position.set(sx, 0.25, sz);
    courseGroup.add(sparkleGroup);

    sparkleLights.push({
      x: sx, z: sz, reward, collected: false,
      mesh: sparkleGroup, gemMat, haloMat,
      phase: rng() * Math.PI * 2,
      colorName: colorSet.name,
      collectRadius: sparkleCollectRadius,
    });
  }
}

// ---- Load Hole ----
function loadHole() {
  const c = courses[holeIndex];
  ball.x = c.bx; ball.z = c.bz; ball.vx = 0; ball.vz = 0;
  holePos.x = c.hx; holePos.z = c.hz;
  obstacles = c.obs;
  walls = c.walls;
  strokes = 0;
  power = 0;
  tapCount = 0;
  gamePhase = 'aiming';

  // Generate secret for this hole
  const difficulty = Math.min(tournamentIndex, 8);
  secretData = generateSecret(c, difficulty, holeIndex, tournamentIndex);
  secretFound = false;
  secretPatternProgress = 0;
  secretHintEl.textContent = secretData.hint;
  secretHintEl.classList.add('visible');
  setTimeout(() => secretHintEl.classList.remove('visible'), 4000);

  buildCourse3D(c);
  ballMesh.visible = true;
  ballMesh.position.set(ball.x, BALL_R, ball.z);
  ballShadow.position.set(ball.x, 0.005, ball.z);
  clubGroup.visible = false;
  clubSwinging = false;

  // Update env map for ball reflections
  ballMesh.visible = false;
  cubeCamera.position.copy(ballMesh.position);
  cubeCamera.update(renderer, scene);
  ballMesh.visible = true;

  holeLabelEl.textContent = `Hole ${holeIndex + 1}/${holesPerTournament}`;
  strokesLabelEl.textContent = 'Strokes: 0';
  parLabelEl.textContent = `Par: ${c.par}`;
  powerBar.classList.add('hidden');
  tapHint.classList.add('hidden');
  powerLabel.textContent = 'Click to aim, then TAP to build power!';
}

// ---- Start Game ----
window.startGame = function() {
  try {
    initAudio();
    startMusic();
    startNatureSounds();
  } catch (error) {
    console.warn('Audio startup failed:', error);
  }
  overlayEl.classList.add('hidden');
  courses = generateCourses(tournamentIndex);
  holeIndex = 0;
  totalScore = 0;
  holeScores = [];
  tournamentNameEl.textContent = `Tournament ${tournamentIndex + 1}`;
  totalScoreEl.textContent = 'Total: 0';
  applyActiveEffect();
  loadHole();
};

overlayBtn.addEventListener('click', () => window.startGame());
shopBtnEl.addEventListener('click', () => window.openShop());

// ---- Physics ----
const FRICTION = 0.985;
const BOUNCE = 0.65;

function updateBall() {
  if (gamePhase !== 'rolling') return;

  ball.x += ball.vx;
  ball.z += ball.vz;
  ball.vx *= FRICTION;
  ball.vz *= FRICTION;

  // Border collisions
  if (ball.x - BALL_R < 0) { ball.x = BALL_R; playWallBounceSound(Math.abs(ball.vx)); ball.vx = Math.abs(ball.vx) * BOUNCE; }
  if (ball.x + BALL_R > CW) { ball.x = CW - BALL_R; playWallBounceSound(Math.abs(ball.vx)); ball.vx = -Math.abs(ball.vx) * BOUNCE; }
  if (ball.z - BALL_R < 0) { ball.z = BALL_R; playWallBounceSound(Math.abs(ball.vz)); ball.vz = Math.abs(ball.vz) * BOUNCE; }
  if (ball.z + BALL_R > CH) { ball.z = CH - BALL_R; playWallBounceSound(Math.abs(ball.vz)); ball.vz = -Math.abs(ball.vz) * BOUNCE; }

  // Obstacle collisions
  for (const ob of obstacles) {
    if (ob.type === 'circle') collideCircle(ob);
    else collideRect(ob);
  }

  // Wall collisions
  for (const w of walls) collideWallSegment(w);

  // Check hole
  const d = dist(ball.x, ball.z, holePos.x, holePos.z);
  const speed = Math.sqrt(ball.vx ** 2 + ball.vz ** 2);
  if (d < HOLE_R - 0.05 && speed < 0.3) {
    ballScored();
    return;
  }

  // Stop when slow
  if (speed < 0.005) {
    ball.vx = 0; ball.vz = 0;
    gamePhase = 'aiming';
    powerLabel.textContent = 'Click to aim, then TAP to build power!';
  }

  // ---- Secret collision detection ----
  if (secretData && !secretFound) {
    if (secretData.type === 'simple') {
      // Direct hit on crystal
      const sd = dist(ball.x, ball.z, secretData.crystal.x, secretData.crystal.z);
      if (sd < BALL_R + secretData.crystal.r) {
        secretFound = true;
        triggerSecretFound();
      }
    } else if (secretData.type === 'pattern') {
      // Check if hitting next target in sequence
      const nextIdx = secretPatternProgress;
      if (nextIdx < secretData.targets.length) {
        const tgt = secretData.targets[nextIdx];
        const td = dist(ball.x, ball.z, tgt.x, tgt.z);
        if (td < BALL_R + tgt.r) {
          tgt.hit = true;
          secretPatternProgress++;
          // Visual feedback — rune lights up
          if (secretTargetMeshes[nextIdx]) {
            secretTargetMeshes[nextIdx].children.forEach(c => {
              if (c.material && c.material.color) c.material.color.setHex(0x44ff88);
              if (c.material && c.material.emissive) c.material.emissive.setHex(0x22ff66);
            });
          }
          // Play chime — ascending pitch per target
          if (audioCtx) {
            const now = audioCtx.currentTime;
            const freq = 440 * Math.pow(2, nextIdx / 6);
            const o = audioCtx.createOscillator();
            o.type = 'sine'; o.frequency.value = freq;
            const g = audioCtx.createGain();
            g.gain.setValueAtTime(0.2, now);
            g.gain.exponentialRampToValueAtTime(0.001, now + 0.5);
            o.connect(g); g.connect(sfxGain);
            o.start(now); o.stop(now + 0.55);
          }
          // Show progress
          powerLabel.textContent = `✨ Rune ${secretPatternProgress}/${secretData.targets.length} activated!`;

          // If all targets hit, now check crystal
          if (secretPatternProgress >= secretData.targets.length) {
            // Crystal becomes fully visible
            if (secretMesh) {
              secretMesh.material.opacity = 0.9;
              secretMesh.material.emissiveIntensity = 1.5;
            }
            powerLabel.textContent = '✨ Crystal awakened! Hit it!';
          }
        }
      } else {
        // All targets done, now check crystal
        const sd = dist(ball.x, ball.z, secretData.crystal.x, secretData.crystal.z);
        if (sd < BALL_R + secretData.crystal.r) {
          secretFound = true;
          triggerSecretFound();
        }
      }
    }
  }

  // ---- Sparkle light collision ----
  sparkleLights.forEach(sl => {
    if (sl.collected) return;
    const sd = dist(ball.x, ball.z, sl.x, sl.z);
    if (sd < (sl.collectRadius || BALL_R + 0.3)) {
      sl.collected = true;
      lightsCollectedThisStroke++;
      addCoins(sl.reward);
      // Sparkle collect sound — bright ascending ding
      if (audioCtx) {
        const now = audioCtx.currentTime;
        const freqs = [880, 1100, 1320];
        freqs.forEach((f, i) => {
          const o = audioCtx.createOscillator();
          o.type = 'sine'; o.frequency.value = f;
          const g = audioCtx.createGain();
          g.gain.setValueAtTime(0.15, now + i * 0.06);
          g.gain.exponentialRampToValueAtTime(0.001, now + i * 0.06 + 0.3);
          o.connect(g); g.connect(sfxGain);
          o.start(now + i * 0.06); o.stop(now + i * 0.06 + 0.35);
        });
      }
      // Visual: light turns off — go dark, stop glowing
      if (sl.mesh) {
        sl.gemMat.emissive.setHex(0x000000);
        sl.gemMat.emissiveIntensity = 0;
        sl.gemMat.opacity = 0.4;
        sl.gemMat.color.setHex(0x333340);
        sl.haloMat.opacity = 0;
        // Hide orbiting dots
        sl.mesh.children.forEach((child, ci) => {
          if (ci >= 2) child.visible = false;
        });
      }
      // Check if ALL lights collected in this single stroke
      if (lightsCollectedThisStroke === sparkleLights.length && sparkleLights.length > 0) {
        awardExclusiveCoin();
      }
    }
  });

  // Update 3D ball
  ballMesh.position.set(ball.x, BALL_R, ball.z);
  ballShadow.position.set(ball.x, 0.005, ball.z);
  // Roll animation + sound
  const rollSpeed = Math.sqrt(ball.vx ** 2 + ball.vz ** 2);
  if (rollSpeed > 0.001) {
    const rollAxis = new THREE.Vector3(-ball.vz, 0, ball.vx).normalize();
    ballMesh.rotateOnWorldAxis(rollAxis, rollSpeed / BALL_R * 0.5);
    playRollSound(rollSpeed);
  }
}

function collideCircle(ob) {
  const dx = ball.x - ob.x, dz = ball.z - ob.z;
  const d = Math.sqrt(dx * dx + dz * dz);
  const minDist = BALL_R + ob.r;
  if (d < minDist && d > 0) {
    const speed = Math.sqrt(ball.vx * ball.vx + ball.vz * ball.vz);
    const nx = dx / d, nz = dz / d;
    ball.x = ob.x + nx * minDist;
    ball.z = ob.z + nz * minDist;
    const dot = ball.vx * nx + ball.vz * nz;
    ball.vx -= 2 * dot * nx;
    ball.vz -= 2 * dot * nz;
    ball.vx *= BOUNCE; ball.vz *= BOUNCE;
    playBounceSound(speed);
  }
}

function collideRect(ob) {
  const hw = ob.w / 2, hd = ob.d / 2;
  const cx = Math.max(ob.x - hw, Math.min(ball.x, ob.x + hw));
  const cz = Math.max(ob.z - hd, Math.min(ball.z, ob.z + hd));
  const dx = ball.x - cx, dz = ball.z - cz;
  const d = Math.sqrt(dx * dx + dz * dz);
  if (d < BALL_R && d > 0) {
    const speed = Math.sqrt(ball.vx * ball.vx + ball.vz * ball.vz);
    const nx = dx / d, nz = dz / d;
    ball.x = cx + nx * BALL_R;
    ball.z = cz + nz * BALL_R;
    const dot = ball.vx * nx + ball.vz * nz;
    ball.vx -= 2 * dot * nx;
    ball.vz -= 2 * dot * nz;
    ball.vx *= BOUNCE; ball.vz *= BOUNCE;
    playBounceSound(speed);
  }
}

function collideWallSegment(w) {
  const ax = w.x2 - w.x1, az = w.z2 - w.z1;
  const len = Math.sqrt(ax * ax + az * az);
  if (len === 0) return;
  const dx = ball.x - w.x1, dz = ball.z - w.z1;
  let t = (dx * ax + dz * az) / (len * len);
  t = Math.max(0, Math.min(1, t));
  const closestX = w.x1 + t * ax;
  const closestZ = w.z1 + t * az;
  const cdx = ball.x - closestX, cdz = ball.z - closestZ;
  const cd = Math.sqrt(cdx * cdx + cdz * cdz);
  const wallThick = 0.15;
  if (cd < BALL_R + wallThick && cd > 0) {
    const speed = Math.sqrt(ball.vx * ball.vx + ball.vz * ball.vz);
    const nx = cdx / cd, nz = cdz / cd;
    ball.x = closestX + nx * (BALL_R + wallThick);
    ball.z = closestZ + nz * (BALL_R + wallThick);
    const dot = ball.vx * nx + ball.vz * nz;
    ball.vx -= 2 * dot * nx;
    ball.vz -= 2 * dot * nz;
    ball.vx *= BOUNCE; ball.vz *= BOUNCE;
    playWallBounceSound(speed);
  }
}

// ---- Scoring ----
let scoredTime = 0;

function ballScored() {
  gamePhase = 'scored';
  scoredTime = Date.now();
  ball.vx = 0; ball.vz = 0;
  ball.x = holePos.x; ball.z = holePos.z;
  playHoleSound();

  const par = courses[holeIndex].par;
  const diff = strokes - par;
  totalScore += diff;
  holeScores.push(strokes);
  totalScoreEl.textContent = `Total: ${totalScore >= 0 ? '+' : ''}${totalScore}`;

  const scoreName = getScoreName(diff);
  powerLabel.textContent = `⛳ ${scoreName}! (${strokes} strokes, par ${par})`;

  setTimeout(() => {
    if (holeIndex < holesPerTournament - 1) {
      holeIndex++;
      loadHole();
    } else {
      endTournament();
    }
  }, 1500);
}

function getScoreName(diff) {
  if (diff <= -3) return 'Albatross';
  if (diff === -2) return 'Eagle';
  if (diff === -1) return 'Birdie';
  if (diff === 0) return 'Par';
  if (diff === 1) return 'Bogey';
  if (diff === 2) return 'Double Bogey';
  return 'Triple Bogey+';
}

// ---- Secret Found Handler ----
function triggerSecretFound() {
  if (!secretData) return;
  const reward = secretData.reward;

  // Sound — magical chime
  if (audioCtx) {
    const now = audioCtx.currentTime;
    const notes = [523.3, 659.3, 784.0, 1047, 1318.5];
    notes.forEach((freq, i) => {
      const t = now + i * 0.1;
      const o = audioCtx.createOscillator();
      o.type = 'sine'; o.frequency.value = freq;
      const g = audioCtx.createGain();
      g.gain.setValueAtTime(0.25, t);
      g.gain.exponentialRampToValueAtTime(0.001, t + 0.8);
      o.connect(g); g.connect(sfxGain);
      o.start(t); o.stop(t + 0.85);
    });
  }

  // Gift reward
  addCoins(reward);
  addStars(1);

  // Hide the crystal with an explosion effect
  if (secretMesh) {
    secretMesh.visible = false;
  }

  // Show toast
  const giftNames = ['Mystery Chest', 'Ancient Relic', 'Golden Orb', 'Crystal Shard', 'Enchanted Gem'];
  const giftName = giftNames[Math.floor(Math.random() * giftNames.length)];
  showSecretToast(
    `🎁 ${giftName}!`,
    secretData.type === 'pattern'
      ? 'You solved the rune pattern!<br>The crystal revealed its treasure.'
      : 'You found the hidden crystal!',
    reward
  );
}

function playSecretChimeSound() {
  // Used for hint
  if (!audioCtx) return;
  const now = audioCtx.currentTime;
  const o = audioCtx.createOscillator();
  o.type = 'sine'; o.frequency.value = 800;
  const g = audioCtx.createGain();
  g.gain.setValueAtTime(0.05, now);
  g.gain.exponentialRampToValueAtTime(0.001, now + 0.3);
  o.connect(g); g.connect(sfxGain);
  o.start(now); o.stop(now + 0.35);
}

function endTournament() {
  const won = totalScore <= 0;

  // Placement: compare player totalScore vs simulated opponents
  // Simulate 3 opponents with random scores for tournament placement
  const opponentScores = [];
  const tRng = mulberry32(tournamentIndex * 777);
  for (let i = 0; i < 3; i++) {
    // Opponents: range from -3 to +6 relative
    opponentScores.push(Math.floor(tRng() * 10) - 3);
  }
  opponentScores.sort((a, b) => a - b);
  // Determine placement
  let placement = 1;
  for (const os of opponentScores) {
    if (os < totalScore) placement++;
  }
  placement = Math.min(placement, 4); // 4th if worse than all

  let placementCoins = 0;
  let placementText = '';
  if (placement === 1) { placementCoins = 100; placementText = '🥇 1st Place! +100 coins'; }
  else if (placement === 2) { placementCoins = 75; placementText = '🥈 2nd Place! +75 coins'; }
  else if (placement === 3) { placementCoins = 50; placementText = '🥉 3rd Place! +50 coins'; }
  else { placementText = '4th Place'; }

  // Round win bonus: 10 coins per hole won (under par)
  let roundWinCoins = 0;
  for (let i = 0; i < holeScores.length; i++) {
    if (holeScores[i] <= courses[i].par) roundWinCoins += 10;
  }

  const totalEarned = placementCoins + roundWinCoins;
  if (totalEarned > 0) addCoins(totalEarned);

  if (won) {
    wins++;
    winsLabelEl.textContent = `Wins: ${wins}`;
    overlayTitle.textContent = '🏆 You Win!';
    playWinSound();
    overlayText.innerHTML = `Tournament ${tournamentIndex + 1} complete!<br>
      Score: ${totalScore >= 0 ? '+' : ''}${totalScore}<br>
      Holes: ${holeScores.join(', ')}<br>
      <span style="color:#ffd700">${placementText}</span><br>
      <span style="color:#ffd700">Round wins: +${roundWinCoins} coins</span><br><br>
      Advancing to Tournament ${tournamentIndex + 2}...`;
    overlayBtn.textContent = 'Next Tournament';
    tournamentIndex++;
  } else {
    overlayTitle.textContent = '😤 Try Again!';
    overlayText.innerHTML = `Tournament ${tournamentIndex + 1} — you went over par.<br>
      Score: +${totalScore}<br>
      Holes: ${holeScores.join(', ')}<br>
      <span style="color:#ffd700">${placementText}</span><br>
      <span style="color:#ffd700">Round wins: +${roundWinCoins} coins</span><br><br>
      Moving on to a new tournament...`;
    overlayBtn.textContent = 'New Tournament';
    tournamentIndex++;
    playLoseSound();
  }
  overlayEl.classList.remove('hidden');
  gamePhase = 'menu';
  saveShopData();
}

// ---- Aim Visuals ----
function updateAimVisuals() {
  if (gamePhase === 'aiming') {
    const angle = Math.atan2(mouseWorldZ - ball.z, mouseWorldX - ball.x);
    const len = 5;
    const positions = aimLine.geometry.attributes.position.array;
    positions[0] = ball.x; positions[1] = 0.12; positions[2] = ball.z;
    positions[3] = ball.x + Math.cos(angle) * len;
    positions[4] = 0.12;
    positions[5] = ball.z + Math.sin(angle) * len;
    aimLine.geometry.attributes.position.needsUpdate = true;
    aimLine.visible = true;
    aimLineMat.color.set(0xffffff);
    aimLineMat.opacity = 0.8;

    const time = Date.now() * 0.003;
    for (let i = 0; i < aimDots.length; i++) {
      const t = (i + 1) / (aimDots.length + 1);
      const pulse = 0.5 + Math.sin(time + i * 0.6) * 0.3;
      aimDots[i].position.set(
        ball.x + Math.cos(angle) * len * t,
        0.12 + Math.sin(time * 2 + i) * 0.02,
        ball.z + Math.sin(angle) * len * t
      );
      aimDots[i].visible = true;
      aimDots[i].material.opacity = 0.3 + pulse * (1 - t);
      aimDots[i].scale.setScalar(0.8 + pulse * 0.5);
    }
  } else if (gamePhase === 'powering') {
    const len = 2 + (power / 100) * 6;
    const positions = aimLine.geometry.attributes.position.array;
    positions[0] = ball.x; positions[1] = 0.12; positions[2] = ball.z;
    positions[3] = ball.x + Math.cos(aimAngle) * len;
    positions[4] = 0.12;
    positions[5] = ball.z + Math.sin(aimAngle) * len;
    aimLine.geometry.attributes.position.needsUpdate = true;
    aimLine.visible = true;

    const r = power / 100;
    aimLineMat.color.setRGB(r, 1 - r * 0.7, 0.15);
    aimLineMat.opacity = 0.6 + r * 0.3;

    for (let i = 0; i < aimDots.length; i++) {
      const t = (i + 1) / (aimDots.length + 1);
      aimDots[i].position.set(
        ball.x + Math.cos(aimAngle) * len * t,
        0.12,
        ball.z + Math.sin(aimAngle) * len * t
      );
      aimDots[i].visible = true;
      aimDots[i].material.color.setRGB(r, 1 - r * 0.7, 0.15);
      aimDots[i].scale.setScalar(0.8 + r * 0.6);
    }
  } else {
    aimLine.visible = false;
    aimDots.forEach(d => d.visible = false);
  }
}

// ---- Scored Sparkle Animation ----
function updateSparkles() {
  if (gamePhase === 'scored') {
    const t = (Date.now() - scoredTime) * 0.004;
    sparkles.forEach((s, i) => {
      s.visible = true;
      const angle = t * 1.2 + (i / sparkles.length) * Math.PI * 2;
      const r = 0.8 + Math.sin(t * 2 + i * 0.7) * 0.4;
      const yBounce = 0.3 + Math.abs(Math.sin(t * 3 + i * 0.8)) * 1.0;
      s.position.set(
        holePos.x + Math.cos(angle) * r,
        yBounce,
        holePos.z + Math.sin(angle) * r
      );
      const hue = ((i / sparkles.length) + t * 0.08) % 1;
      s.material.color.setHSL(hue, 0.9, 0.65);
      s.material.opacity = 0.5 + Math.sin(t * 4 + i) * 0.4;
      s.scale.setScalar(0.6 + Math.sin(t * 5 + i * 2) * 0.3);
    });
    starSparkles.forEach((s, i) => {
      s.visible = true;
      const angle = -t * 0.8 + (i / starSparkles.length) * Math.PI * 2;
      const r = 1.2 + Math.sin(t * 1.5 + i) * 0.3;
      s.position.set(
        holePos.x + Math.cos(angle) * r,
        0.8 + Math.sin(t * 2.5 + i * 1.2) * 0.5,
        holePos.z + Math.sin(angle) * r
      );
      s.rotation.z = t * 2 + i;
      s.scale.setScalar(0.6 + Math.sin(t * 3 + i) * 0.4);
    });
    // Animate ball sinking
    const elapsed = (Date.now() - scoredTime) / 1000;
    ballMesh.position.y = Math.max(-0.3, BALL_R - elapsed * 0.5);
    ballShadow.visible = ballMesh.position.y > 0;
  } else {
    sparkles.forEach(s => s.visible = false);
    starSparkles.forEach(s => s.visible = false);
    ballShadow.visible = true;
  }
}

// ---- Main Loop ----
let frameCount = 0;
// Smooth camera follow
const camTarget = new THREE.Vector3(CW / 2, 0, CH / 2 - 1);
const camLookTarget = new THREE.Vector3(CW / 2, 0, CH / 2 - 1);

// Flag mesh ref for animation (set during buildCourse3D)
let flagMeshRef = null;
let waterMeshRefs = [];
let fishList = [];
let splashParticles = [];

function animate() {
  requestAnimationFrame(animate);
  const time = Date.now() * 0.001;

  updateBall();
  updateClubSwing();
  updateAimVisuals();
  updateSparkles();

  // ---- Animate floating particles ----
  const ppos = particles.geometry.attributes.position.array;
  for (let i = 0; i < particleCount; i++) {
    const pd = particleData[i];
    ppos[i * 3] += pd.vx + Math.sin(time * 0.5 + pd.phase) * 0.002;
    ppos[i * 3 + 1] += pd.vy + Math.sin(time * 0.3 + pd.phase * 2) * 0.001;
    ppos[i * 3 + 2] += pd.vz + Math.cos(time * 0.4 + pd.phase) * 0.002;
    // Wrap around
    if (ppos[i * 3] < -15) ppos[i * 3] = CW + 15;
    if (ppos[i * 3] > CW + 15) ppos[i * 3] = -15;
    if (ppos[i * 3 + 1] < 0.3) ppos[i * 3 + 1] = 6;
    if (ppos[i * 3 + 1] > 7) ppos[i * 3 + 1] = 0.5;
    if (ppos[i * 3 + 2] < -15) ppos[i * 3 + 2] = CH + 15;
    if (ppos[i * 3 + 2] > CH + 15) ppos[i * 3 + 2] = -15;
  }
  particles.geometry.attributes.position.needsUpdate = true;
  particleMat.opacity = 0.3 + Math.sin(time * 0.7) * 0.15;

  // ---- Fireflies (pulsing, drifting) ----
  fireflies.forEach(ff => {
    const t = time * ff.speed + ff.phase;
    ff.mesh.position.x = ff.baseX + Math.sin(t * 0.7) * ff.driftRadius;
    ff.mesh.position.y = ff.baseY + Math.sin(t * 0.5 + 1) * 0.8;
    ff.mesh.position.z = ff.baseZ + Math.cos(t * 0.6 + 2) * ff.driftRadius * 0.7;
    // Slow pulse on/off
    const pulse = Math.sin(time * ff.pulseSpeed + ff.pulsePhase);
    const glow = pulse > 0.2 ? (pulse - 0.2) * 1.25 * ff.brightness : 0;
    ff.mat.opacity = glow;
    ff.glowMat.opacity = glow * 0.35;
  });

  // ---- Dandelion seeds (lazy drift) ----
  dandelionSeeds.forEach(ds => {
    const m = ds.mesh;
    m.position.x += ds.vx + Math.sin(time * 0.3 + ds.phase) * 0.003;
    m.position.y += ds.vy + Math.sin(time * 0.2 + ds.phase * 2) * 0.001;
    m.position.z += ds.vz + Math.cos(time * 0.25 + ds.phase) * 0.003;
    m.rotation.y += ds.rotSpeed;
    m.rotation.x = Math.sin(time * 0.4 + ds.phase) * 0.3;
    // Wrap around
    if (m.position.x < -8) m.position.x = CW + 8;
    if (m.position.x > CW + 8) m.position.x = -8;
    if (m.position.y < 0.5) m.position.y = 5;
    if (m.position.y > 7) m.position.y = 1;
    if (m.position.z < -8) m.position.z = CH + 8;
    if (m.position.z > CH + 8) m.position.z = -8;
  });

  // ---- Shooting stars ----
  shootingStars.forEach(ss => {
    if (!ss.active) {
      ss.nextTime -= 0.016;
      if (ss.nextTime <= 0) {
        // Launch a new shooting star
        ss.active = true;
        ss.progress = 0;
        ss.duration = 0.5 + Math.random() * 0.8;
        ss.tailLen = 8 + Math.random() * 12;
        // Start from a high point in the sky dome
        const angle = Math.random() * Math.PI * 2;
        const elev = 40 + Math.random() * 30;
        const dist2 = 60 + Math.random() * 40;
        ss.startX = CW / 2 + Math.cos(angle) * dist2;
        ss.startY = elev;
        ss.startZ = CH / 2 + Math.sin(angle) * dist2;
        // Direction: generally downward and across
        const da = angle + Math.PI * 0.6 + (Math.random() - 0.5) * 0.8;
        ss.dirX = Math.cos(da) * 80;
        ss.dirY = -20 - Math.random() * 30;
        ss.dirZ = Math.sin(da) * 80;
      }
    } else {
      ss.progress += 0.016 / ss.duration;
      if (ss.progress >= 1) {
        ss.active = false;
        ss.nextTime = 8 + Math.random() * 25;
        ss.mat.opacity = 0;
        ss.headMat.opacity = 0;
      } else {
        const p = ss.progress;
        const headX = ss.startX + ss.dirX * p;
        const headY = ss.startY + ss.dirY * p;
        const headZ = ss.startZ + ss.dirZ * p;
        const tailP = Math.max(0, p - 0.15);
        const tailX = ss.startX + ss.dirX * tailP;
        const tailY = ss.startY + ss.dirY * tailP;
        const tailZ = ss.startZ + ss.dirZ * tailP;
        const pos = ss.line.geometry.attributes.position.array;
        pos[0] = headX; pos[1] = headY; pos[2] = headZ;
        pos[3] = tailX; pos[4] = tailY; pos[5] = tailZ;
        ss.line.geometry.attributes.position.needsUpdate = true;
        // Fade in then out
        const fade = p < 0.2 ? p / 0.2 : (1 - p) / 0.8;
        ss.mat.opacity = fade * 0.7;
        ss.headMesh.position.set(headX, headY, headZ);
        ss.headMat.opacity = fade * 0.5;
      }
    }
  });

  // ---- Ground glow spots (soft breathing) ----
  groundGlows.forEach(gg => {
    const pulse = (Math.sin(time * gg.speed + gg.phase) + 1) * 0.5;
    gg.mat.opacity = pulse * gg.maxOpacity;
  });

  // ---- Breathing ambient light ----
  const breathe = Math.sin(time * 0.4) * 0.08;
  ambientLight.intensity = 0.3 + breathe;

  // ---- Ball trail ----
  const ballSpeed = Math.sqrt(ball.vx ** 2 + ball.vz ** 2);
  if (gamePhase === 'rolling' && ballSpeed > 0.02) {
    // Shift positions
    for (let i = trailCount - 1; i > 0; i--) {
      trailPositions[i].x = trailPositions[i - 1].x;
      trailPositions[i].z = trailPositions[i - 1].z;
    }
    trailPositions[0].x = ball.x;
    trailPositions[0].z = ball.z;
    const trailIntensity = Math.min(ballSpeed * 5, 1);
    for (let i = 0; i < trailCount; i++) {
      trailMeshes[i].visible = true;
      trailMeshes[i].position.set(trailPositions[i].x, BALL_R * 0.5, trailPositions[i].z);
      trailMeshes[i].material.opacity = 0.25 * (1 - i / trailCount) * trailIntensity;

      // Shop effects on trail
      if (activeEffect === 'rainbow_trail') {
        const hue = ((time * 0.5 + i * 0.08) % 1);
        trailMeshes[i].material.color.setHSL(hue, 0.9, 0.6);
        trailMeshes[i].material.opacity = 0.4 * (1 - i / trailCount) * trailIntensity;
      } else if (activeEffect === 'comet_trail') {
        const heat = 1 - i / trailCount;
        trailMeshes[i].material.color.setHSL(0.07 - heat * 0.04, 1.0, 0.4 + heat * 0.3);
        trailMeshes[i].material.opacity = 0.5 * heat * trailIntensity;
        trailMeshes[i].scale.setScalar(1 + heat * 0.8);
      } else if (activeEffect === 'aurora_trail') {
        const hue = ((time * 0.3 + i * 0.12) % 1) * 0.4 + 0.45; // green-blue-purple range
        trailMeshes[i].material.color.setHSL(hue, 0.8, 0.5);
        trailMeshes[i].material.opacity = 0.35 * (1 - i / trailCount) * trailIntensity;
        trailMeshes[i].scale.setScalar(1 + Math.sin(time * 3 + i * 0.5) * 0.3);
      } else if (activeEffect === 'phoenix_trail') {
        const flame = 1 - i / trailCount;
        const flicker = Math.sin(time * 8 + i * 1.5) * 0.15;
        trailMeshes[i].material.color.setHSL(0.05 + flame * 0.08 + flicker * 0.02, 1.0, 0.35 + flame * 0.35);
        trailMeshes[i].material.opacity = 0.55 * flame * trailIntensity;
        trailMeshes[i].scale.setScalar(1 + flame * 1.2 + flicker);
      } else if (activeEffect === 'snowflake_trail') {
        trailMeshes[i].material.color.setHSL(0.55, 0.3, 0.8 + Math.sin(time * 4 + i) * 0.1);
        trailMeshes[i].material.opacity = 0.35 * (1 - i / trailCount) * trailIntensity;
        trailMeshes[i].scale.setScalar(0.8 + Math.sin(time * 5 + i * 0.8) * 0.4);
      } else if (activeEffect === 'sakura_trail') {
        const pink = 0.95 + Math.sin(time * 2 + i * 0.5) * 0.03;
        trailMeshes[i].material.color.setHSL(pink, 0.6, 0.75);
        trailMeshes[i].material.opacity = 0.4 * (1 - i / trailCount) * trailIntensity;
        trailMeshes[i].scale.setScalar(0.7 + Math.sin(time * 3 + i * 1.2) * 0.5);
        trailMeshes[i].position.y = BALL_R * 0.5 + Math.sin(time * 2.5 + i * 0.7) * 0.2;
      } else if (activeEffect === 'electric_trail') {
        const spark = Math.random() > 0.5 ? 1.0 : 0.4;
        trailMeshes[i].material.color.setHSL(0.6, 0.9, 0.5 + spark * 0.3);
        trailMeshes[i].material.opacity = 0.45 * (1 - i / trailCount) * trailIntensity * spark;
        trailMeshes[i].scale.setScalar(0.6 + spark * 0.8);
      } else if (activeEffect === 'prism_trail') {
        const hue = ((i * 0.15 + time * 0.4) % 1);
        trailMeshes[i].material.color.setHSL(hue, 1.0, 0.65);
        trailMeshes[i].material.opacity = 0.5 * (1 - i / trailCount) * trailIntensity;
        const sc = 0.5 + (1 - i / trailCount) * 0.8 + Math.sin(time * 6 + i * 2) * 0.2;
        trailMeshes[i].scale.setScalar(sc);
      } else if (activeEffect === 'dragon_trail') {
        const flame = 1 - i / trailCount;
        const breath = Math.sin(time * 6 + i * 1.0) * 0.2;
        trailMeshes[i].material.color.setHSL(0.02 + flame * 0.1 + breath * 0.03, 1.0, 0.3 + flame * 0.4);
        trailMeshes[i].material.opacity = 0.6 * flame * trailIntensity;
        trailMeshes[i].scale.setScalar(1.2 + flame * 1.5 + breath);
      } else if (activeEffect === 'ember_trail') {
        const ember = 1 - i / trailCount;
        const drift = Math.sin(time * 4 + i * 2.0) * 0.1;
        trailMeshes[i].material.color.setHSL(0.06 + ember * 0.04 + drift * 0.02, 0.9, 0.3 + ember * 0.3);
        trailMeshes[i].material.opacity = 0.45 * ember * trailIntensity;
        trailMeshes[i].scale.setScalar(0.7 + ember * 0.6 + drift);
        trailMeshes[i].position.y = BALL_R * 0.5 + Math.sin(time * 3 + i * 0.9) * 0.15;
      } else {
        trailMeshes[i].material.color.setHex(0xffffff);
        trailMeshes[i].scale.setScalar(1);
      }
    }
  } else {
    trailMeshes.forEach(t => { t.visible = false; t.scale.setScalar(1); });
  }

  // ---- Shop: Stardust Aura & similar particle auras ----
  if (activeEffect === 'stardust_aura' || activeEffect === 'firefly_aura' || activeEffect === 'music_notes' || activeEffect === 'heart_aura' || activeEffect === 'celestial_aura') {
    stardustParticles.forEach((sp, i) => {
      sp.mesh.visible = true;
      let a, r, hue, opacity;
      if (activeEffect === 'firefly_aura') {
        a = time * 1.5 + sp.phase;
        r = 0.6 + Math.sin(time * 0.8 + sp.phase) * 0.25;
        hue = 0.17 + Math.sin(time + sp.phase) * 0.03; // warm yellow-green
        opacity = Math.sin(time * 3 + sp.phase) > 0.2 ? 0.5 : 0.05; // blink on/off
      } else if (activeEffect === 'music_notes') {
        a = time * 2.0 + sp.phase;
        r = 0.55 + Math.sin(time * 1.2 + sp.phase) * 0.2;
        hue = (i * 0.12 + time * 0.15) % 1;
        opacity = 0.35 + Math.sin(time * 5 + sp.phase) * 0.25;
      } else if (activeEffect === 'heart_aura') {
        a = time * 1.8 + sp.phase;
        r = 0.4 + Math.sin(time * 1.0 + sp.phase) * 0.15;
        hue = 0.95 + Math.sin(time * 0.5 + sp.phase) * 0.03; // pinks
        opacity = 0.45 + Math.sin(time * 2 + sp.phase) * 0.2;
      } else if (activeEffect === 'celestial_aura') {
        a = time * 1.2 + sp.phase;
        r = 0.7 + Math.sin(time * 0.6 + sp.phase) * 0.3;
        hue = (0.15 + i * 0.07 + time * 0.05) % 1; // golden to blue
        opacity = 0.4 + Math.sin(time * 1.5 + sp.phase) * 0.25;
      } else {
        a = time * 2.5 + sp.phase;
        r = 0.5 + Math.sin(time * 1.5 + sp.phase) * 0.15;
        hue = (time * 0.1 + i * 0.08) % 1;
        opacity = 0.4 + Math.sin(time * 4 + sp.phase) * 0.3;
      }
      sp.mesh.position.set(
        ball.x + Math.cos(a) * r,
        BALL_R + Math.sin(a * 1.3 + sp.phase) * 0.3,
        ball.z + Math.sin(a) * r
      );
      sp.mat.opacity = opacity;
      sp.mat.color.setHSL(hue, 0.7, 0.7);
    });
  }

  // ---- Shop: Neon Glow ----
  if (activeEffect === 'neon_glow' && neonGlowMesh.visible) {
    neonGlowMesh.position.set(ball.x, 0.008, ball.z);
    const np = 0.6 + Math.sin(time * 2.0) * 0.2;
    neonGlowMat.opacity = np * 0.12;
    neonGlowMesh.scale.setScalar(0.8 + np * 0.4);
    // Shift hue gently
    const nh = (time * 0.05) % 1;
    neonGlowMat.color.setHSL(nh * 0.3 + 0.7, 0.8, 0.5);
  }

  // ---- Shop: Crystal Ball inner glow pulse ----
  if (activeEffect === 'crystal_ball') {
    const cp = 0.5 + Math.sin(time * 1.5) * 0.3;
    ballMat.emissiveIntensity = 0.2 + cp * 0.2;
    ballMat.opacity = 0.5 + cp * 0.2;
  }

  // ---- Shop: Golden Ball shimmer ----
  if (activeEffect === 'golden_ball') {
    const gp = 0.5 + Math.sin(time * 2.0) * 0.3;
    ballMat.emissiveIntensity = 0.1 + gp * 0.15;
  }

  // ---- Shop: Pulse Glow ----
  if (activeEffect === 'pulse_glow' && neonGlowMesh.visible) {
    neonGlowMesh.position.set(ball.x, 0.008, ball.z);
    const pp = Math.sin(time * 3.0) * 0.5 + 0.5;
    neonGlowMat.opacity = pp * 0.18;
    neonGlowMesh.scale.setScalar(0.6 + pp * 0.8);
  }

  // ---- Shop: Lava Ball pulse ----
  if (activeEffect === 'lava_ball') {
    const lp = 0.5 + Math.sin(time * 2.5) * 0.3;
    ballMat.emissiveIntensity = 0.5 + lp * 0.4;
    if (neonGlowMesh.visible) {
      neonGlowMesh.position.set(ball.x, 0.008, ball.z);
      neonGlowMat.opacity = lp * 0.14;
      neonGlowMesh.scale.setScalar(0.7 + lp * 0.5);
    }
  }

  // ---- Shop: Ice Ball shimmer ----
  if (activeEffect === 'ice_ball') {
    const ip = 0.5 + Math.sin(time * 1.8) * 0.3;
    ballMat.emissiveIntensity = 0.15 + ip * 0.2;
  }

  // ---- Shop: Bubble Ball iridescence ----
  if (activeEffect === 'bubble_ball') {
    const bh = (time * 0.08) % 1;
    ballMat.emissive.setHSL(bh, 0.4, 0.3);
    ballMat.emissiveIntensity = 0.15 + Math.sin(time * 2) * 0.1;
  }

  // ---- Shop: Void Ball warp ----
  if (activeEffect === 'void_ball' && neonGlowMesh.visible) {
    neonGlowMesh.position.set(ball.x, 0.008, ball.z);
    const vp = 0.5 + Math.sin(time * 1.5) * 0.3;
    neonGlowMat.opacity = vp * 0.15;
    neonGlowMesh.scale.setScalar(0.9 + Math.sin(time * 2) * 0.4);
    ballMat.emissiveIntensity = 0.2 + Math.sin(time * 3) * 0.15;
  }

  // ---- Shop: Lightning Ball flicker ----
  if (activeEffect === 'lightning_ball') {
    const lk = Math.random() > 0.85 ? 1.0 : 0.4;
    ballMat.emissiveIntensity = 0.3 + lk * 0.4;
    if (neonGlowMesh.visible) {
      neonGlowMesh.position.set(ball.x, 0.008, ball.z);
      neonGlowMat.opacity = lk * 0.18;
      neonGlowMesh.scale.setScalar(0.8 + lk * 0.6);
    }
  }

  // ---- Shop: Eclipse Ball corona ----
  if (activeEffect === 'eclipse_ball' && neonGlowMesh.visible) {
    neonGlowMesh.position.set(ball.x, 0.008, ball.z);
    const ep = 0.5 + Math.sin(time * 1.2) * 0.3;
    neonGlowMat.opacity = ep * 0.16;
    neonGlowMesh.scale.setScalar(1.0 + ep * 0.5);
  }

  // ---- Shop: Diamond Ball sparkle ----
  if (activeEffect === 'diamond_ball') {
    const dp = Math.sin(time * 3) * 0.5 + 0.5;
    ballMat.emissiveIntensity = 0.25 + dp * 0.2;
    const dh = (time * 0.06) % 1;
    ballMat.emissive.setHSL(dh, 0.3, 0.5);
  }

  // ---- Animate flag wave ----
  if (flagMeshRef) {
    const geo = flagMeshRef.geometry;
    const positions = geo.attributes.position;
    if (!flagMeshRef.userData.origPositions) {
      flagMeshRef.userData.origPositions = positions.array.slice();
    }
    const orig = flagMeshRef.userData.origPositions;
    for (let i = 0; i < positions.count; i++) {
      const ox = orig[i * 3], oy = orig[i * 3 + 1];
      const wave = Math.sin(time * 4 + ox * 6) * 0.04 * ox;
      positions.setZ(i, orig[i * 3 + 2] + wave);
    }
    positions.needsUpdate = true;
  }

  // ---- Animate water ripple (all ponds) ----
  waterMeshRefs.forEach((wm, wi) => {
    wm.material.opacity = 0.45 + Math.sin(time * 1.5 + wi * 2) * 0.08;
    wm.position.y = -0.01 + Math.sin(time * 0.8 + wi) * 0.008;
  });

  // ---- Animate fish swimming & jumping ----
  fishList.forEach(fish => {
    const t = time + fish.phaseOffset;

    // Check for jump
    const timeSinceLastJump = time - fish.lastJump;
    if (fish.jumpTime < 0 && timeSinceLastJump > fish.jumpInterval) {
      fish.jumpTime = time;
      fish.lastJump = time;
      // Trigger splash sound
      if (audioCtx) {
        const now = audioCtx.currentTime;
        const bufSize = Math.floor(audioCtx.sampleRate * 0.15);
        const buf = audioCtx.createBuffer(1, bufSize, audioCtx.sampleRate);
        const d = buf.getChannelData(0);
        for (let i = 0; i < bufSize; i++) {
          const st = i / audioCtx.sampleRate;
          d[i] = (Math.random() * 2 - 1) * Math.exp(-st * 20) * 0.15;
        }
        const s = audioCtx.createBufferSource();
        s.buffer = buf;
        const lp = audioCtx.createBiquadFilter();
        lp.type = 'lowpass'; lp.frequency.value = 3000;
        s.connect(lp); lp.connect(sfxGain);
        s.start(now);
      }
    }

    const isJumping = fish.jumpTime >= 0;
    let jumpProgress = 0;

    if (isJumping) {
      jumpProgress = (time - fish.jumpTime) / fish.jumpDuration;
      if (jumpProgress >= 1) {
        fish.jumpTime = -1;
        jumpProgress = 0;
        // Splash particles on reentry
        let spawned = 0;
        for (const sp of splashParticles) {
          if (!sp.active && spawned < 5) {
            sp.active = true;
            sp.mesh.visible = true;
            sp.mesh.position.copy(fish.mesh.position);
            sp.mesh.position.y = 0.05;
            const sa = Math.random() * Math.PI * 2;
            const sv = 0.02 + Math.random() * 0.03;
            sp.vx = Math.cos(sa) * sv;
            sp.vy = 0.04 + Math.random() * 0.04;
            sp.vz = Math.sin(sa) * sv;
            sp.life = 0.6 + Math.random() * 0.3;
            spawned++;
          }
        }
      }
    }

    // Swim in a figure-8 / oval path
    const swimX = fish.pondX + Math.cos(t * fish.speed) * fish.swimRadius;
    const swimZ = fish.pondZ + Math.sin(t * fish.speed * 0.7) * fish.swimRadius * 0.6;

    // Face direction of movement
    const dx = swimX - fish.mesh.position.x;
    const dz = swimZ - fish.mesh.position.z;
    if (Math.abs(dx) > 0.001 || Math.abs(dz) > 0.001) {
      fish.mesh.rotation.y = Math.atan2(dx, dz);
    }

    fish.mesh.position.x = swimX;
    fish.mesh.position.z = swimZ;

    if (isJumping && jumpProgress < 1) {
      // Parabolic arc
      const jp = jumpProgress;
      const height = fish.jumpHeight * 4 * jp * (1 - jp); // parabola peaking at 0.5
      fish.mesh.position.y = -0.02 + height;
      // Tilt fish during jump — nose up on ascent, nose down on descent
      fish.mesh.rotation.x = (0.5 - jp) * Math.PI * 0.6;
      // Slight twist
      fish.mesh.rotation.z = Math.sin(jp * Math.PI) * 0.3;
    } else {
      fish.mesh.position.y = -0.02 + Math.sin(t * 2) * 0.01;
      fish.mesh.rotation.x = 0;
      fish.mesh.rotation.z = 0;
    }

    // Tail wag
    const wagSpeed = isJumping ? 12 : 5;
    const wagAmount = isJumping ? 0.5 : 0.3;
    fish.tail.rotation.y = Math.PI / 2 + Math.sin(t * wagSpeed) * wagAmount;
  });

  // ---- Animate splash particles ----
  splashParticles.forEach(sp => {
    if (!sp.active) return;
    sp.mesh.position.x += sp.vx;
    sp.mesh.position.y += sp.vy;
    sp.mesh.position.z += sp.vz;
    sp.vy -= 0.002; // gravity
    sp.life -= 0.016;
    sp.mesh.material.opacity = Math.max(0, sp.life / 0.6) * 0.7;
    if (sp.life <= 0 || sp.mesh.position.y < -0.1) {
      sp.active = false;
      sp.mesh.visible = false;
    }
  });

  // ---- Animate secret crystal (float, spin, glow pulse) ----
  if (secretMesh && secretMesh.visible && secretData && !secretFound) {
    secretMesh.rotation.y = time * 1.5;
    secretMesh.rotation.x = Math.sin(time * 0.8) * 0.2;
    secretMesh.position.y = 0.35 + Math.sin(time * 2) * 0.12;
    // Pulse emissive
    const pulse = 0.3 + Math.sin(time * 3) * 0.25;
    secretMesh.material.emissiveIntensity = pulse;
    // Proximity hint — chime when ball is near crystal
    if (gamePhase === 'aiming' || gamePhase === 'rolling') {
      const dToCrystal = dist(ball.x, ball.z, secretData.crystal.x, secretData.crystal.z);
      if (dToCrystal < 5) {
        secretMesh.material.opacity = 0.5 + (1 - dToCrystal / 5) * 0.4;
      }
    }
  }

  // ---- Animate sparkle lights ----
  sparkleLights.forEach(sl => {
    if (sl.collected || !sl.mesh || !sl.mesh.visible) return;
    // Gentle float and spin
    sl.mesh.position.y = 0.25 + Math.sin(time * 1.8 + sl.phase) * 0.08;
    sl.mesh.children[0].rotation.y = time * 2.0 + sl.phase;
    sl.mesh.children[0].rotation.x = Math.sin(time * 1.2 + sl.phase) * 0.15;
    // Pulse glow
    const gp = 0.5 + Math.sin(time * 2.5 + sl.phase) * 0.35;
    sl.gemMat.emissiveIntensity = 0.4 + gp * 0.5;
    sl.haloMat.opacity = 0.08 + gp * 0.08;
    // Scale halo ring
    sl.mesh.children[1].scale.setScalar(0.8 + gp * 0.4);
    // Orbit the tiny dots around the gem
    sl.mesh.children.forEach((child, ci) => {
      if (ci < 2) return; // skip gem and halo
      const oa = time * 3 + (child.userData.orbitPhase || 0) + sl.phase;
      child.position.set(Math.cos(oa) * 0.2, Math.sin(oa * 0.7) * 0.08, Math.sin(oa) * 0.2);
    });
  });
  // Animate rune targets (subtle pulse)
  if (secretData && secretData.type === 'pattern' && !secretFound) {
    secretTargetMeshes.forEach((rm, idx) => {
      if (secretData.targets[idx] && !secretData.targets[idx].hit) {
        rm.children.forEach(c => {
          if (c.geometry && c.geometry.type === 'TorusGeometry') {
            c.rotation.z = time * 0.5 + idx;
            c.material.opacity = 0.3 + Math.sin(time * 2 + idx * 1.5) * 0.15;
          }
        });
      }
    });
  }

  // Smooth camera: track ball gently
  if (gamePhase === 'rolling' || gamePhase === 'aiming' || gamePhase === 'powering') {
    camLookTarget.set(
      CW / 2 + (ball.x - CW / 2) * 0.15,
      0,
      CH / 2 - 1 + (ball.z - CH / 2) * 0.1
    );
  }
  camTarget.lerp(camLookTarget, 0.03);
  camera.lookAt(camTarget);

  // Keep sky dome centered on camera
  skyDome.position.copy(camera.position);

  // Update ball shadow — scale with height
  ballShadow.material.opacity = ballMesh.visible ? 0.22 : 0;

  // Refresh env map occasionally
  frameCount++;
  if (frameCount % 180 === 1 && gamePhase !== 'rolling') {
    ballMesh.visible = false;
    cubeCamera.position.copy(ballMesh.position);
    cubeCamera.update(renderer, scene);
    ballMesh.visible = true;
  }

  renderer.render(scene, camera);
}

animate();
</script>
</body>
</html>
