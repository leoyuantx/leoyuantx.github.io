let ownedItems = {}; // { itemId: true }
let activeEffect = null; // itemId or null

// Load from localStorage
try {
  const saved = JSON.parse(localStorage.getItem('tg_shop') || '{}');
  if (saved.coins !== undefined) coins = saved.coins;
  if (saved.stars !== undefined) stars = saved.stars;
  if (saved.exclusiveCoins !== undefined) exclusiveCoins = saved.exclusiveCoins;
  if (saved.owned) ownedItems = saved.owned;
  if (saved.active) activeEffect = saved.active;
  if (saved.wins !== undefined) wins = saved.wins;
  if (saved.tournamentIndex !== undefined) tournamentIndex = saved.tournamentIndex;
} catch(e) {}

function saveShopData() {
  try {
    localStorage.setItem('tg_shop', JSON.stringify({
      coins, stars, exclusiveCoins, owned: ownedItems, active: activeEffect,
      wins, tournamentIndex,
    }));
  } catch(e) {}
}

