<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Twilight Golf - Relax & Play</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&display=swap');
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  background: #0a0818;
  display: flex; justify-content: center; align-items: center;
  height: 100vh; font-family: 'Nunito', 'Segoe UI', sans-serif;
  overflow: hidden; user-select: none;
}
#container { position: relative; width: 100vw; height: 100vh; }
canvas { display: block; cursor: crosshair; }

/* Vignette overlay */
#vignette {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  pointer-events: none; z-index: 5;
  background: radial-gradient(ellipse at 50% 50%, transparent 60%, rgba(15,5,30,0.4) 100%);
}

#ui {
  position: absolute; top: 12px; left: 50%; transform: translateX(-50%);
  color: #fff; text-align: center; pointer-events: none; z-index: 10;
  background: linear-gradient(180deg, rgba(20,10,40,0.75) 0%, rgba(20,10,40,0.45) 80%, transparent 100%);
  padding: 14px 36px 20px; border-radius: 0 0 22px 22px;
  min-width: 380px;
  border: 1px solid rgba(200,170,255,0.12);
  border-top: none;
  backdrop-filter: blur(12px) saturate(1.4);
  box-shadow: 0 8px 32px rgba(0,0,0,0.3), inset 0 -1px 0 rgba(200,170,255,0.08);
}
#ui h2 {
  font-size: 20px; color: #e8c8ff; margin-bottom: 6px; font-weight: 900;
  letter-spacing: 2px; text-transform: uppercase;
  text-shadow: 0 0 16px rgba(200,170,255,0.5), 0 0 40px rgba(200,170,255,0.15);
}
#ui .info {
  font-size: 13px; color: rgba(255,255,255,0.85); font-weight: 700;
  letter-spacing: 0.5px;
}
#ui .info span {
  display: inline-block; padding: 2px 8px; margin: 0 2px;
  background: rgba(255,255,255,0.06); border-radius: 8px;
}

#overlay {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  display: flex; justify-content: center; align-items: center;
  background: radial-gradient(ellipse at 40% 40%, rgba(30,15,50,0.7) 0%, rgba(5,2,15,0.9) 100%);
  z-index: 20; flex-direction: column;
  backdrop-filter: blur(10px) saturate(1.3);
  overflow: hidden;
}
#overlay.hidden { display: none; }
.hidden { display: none !important; }
#overlay > :not(.menu-backdrop) {
  position: relative;
  z-index: 2;
}
#overlay .menu-backdrop {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}
#overlay .menu-backdrop::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 20% 18%, rgba(234,204,255,0.22) 0 0.8%, transparent 1.2%),
    radial-gradient(circle at 75% 22%, rgba(255,244,205,0.18) 0 1.1%, transparent 1.7%),
    radial-gradient(circle at 62% 12%, rgba(255,255,255,0.16) 0 0.5%, transparent 0.9%),
    radial-gradient(circle at 29% 28%, rgba(255,255,255,0.13) 0 0.4%, transparent 0.8%),
    radial-gradient(circle at 85% 14%, rgba(255,255,255,0.14) 0 0.45%, transparent 0.85%),
    radial-gradient(circle at 14% 72%, rgba(135,255,220,0.08) 0, transparent 15%),
    radial-gradient(circle at 78% 68%, rgba(255,214,120,0.09) 0, transparent 18%),
    radial-gradient(circle at 50% 82%, rgba(255,140,180,0.08) 0, transparent 26%),
    linear-gradient(180deg, rgba(8,8,28,0.55) 0%, rgba(20,10,40,0.26) 34%, rgba(30,10,30,0.2) 62%, rgba(5,2,15,0.55) 100%);
}
#overlay .menu-backdrop::after {
  content: '';
  position: absolute;
  left: -8%;
  right: -8%;
  bottom: -6%;
  height: 46%;
  background:
    radial-gradient(ellipse at 50% 72%, rgba(80,255,225,0.12) 0, transparent 26%),
    radial-gradient(ellipse at 52% 76%, rgba(255,218,130,0.08) 0, transparent 18%),
    linear-gradient(180deg, rgba(28,18,54,0.2) 0%, rgba(10,8,20,0.74) 100%);
  clip-path: polygon(0 78%, 8% 68%, 18% 73%, 28% 60%, 39% 74%, 51% 55%, 60% 70%, 72% 58%, 83% 72%, 92% 63%, 100% 78%, 100% 100%, 0 100%);
}
#overlay .menu-pond {
  position: absolute;
  left: 50%;
  bottom: 13%;
  width: min(34vw, 420px);
  height: min(10vw, 110px);
  transform: translateX(-50%);
  border-radius: 50%;
  background:
    radial-gradient(ellipse at 50% 40%, rgba(160,255,245,0.28) 0%, rgba(80,205,225,0.18) 34%, rgba(35,95,140,0.12) 58%, rgba(10,25,40,0) 72%),
    radial-gradient(ellipse at 50% 60%, rgba(255,245,200,0.12) 0%, transparent 52%);
  filter: blur(1px);
  opacity: 0.85;
}
#overlay .menu-pond::before,
#overlay .menu-pond::after {
  content: '';
  position: absolute;
  inset: 18% 9%;
  border-radius: 50%;
  border: 1px solid rgba(170,255,235,0.14);
}
#overlay .menu-pond::after {
  inset: 30% 19%;
  border-color: rgba(255,235,175,0.12);
}
#overlay .menu-firefly {
  position: absolute;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,248,180,0.95) 0%, rgba(255,210,90,0.5) 45%, rgba(255,210,90,0) 100%);
  box-shadow: 0 0 18px rgba(255,220,120,0.45);
  animation: menuFloat 7s ease-in-out infinite;
}
#overlay .menu-firefly.f1 { left: 18%; top: 24%; animation-delay: 0s; }
#overlay .menu-firefly.f2 { left: 76%; top: 32%; animation-delay: 1.6s; }
#overlay .menu-firefly.f3 { left: 68%; top: 68%; animation-delay: 3.2s; }
#overlay .menu-firefly.f4 { left: 27%; top: 64%; animation-delay: 2.1s; }
@keyframes menuFloat {
  0%, 100% { transform: translate3d(0, 0, 0) scale(0.9); opacity: 0.5; }
  30% { transform: translate3d(18px, -12px, 0) scale(1.1); opacity: 0.95; }
  60% { transform: translate3d(-10px, 10px, 0) scale(0.8); opacity: 0.4; }
}
#overlay h1 {
  color: #e8c8ff; font-size: 60px; margin-bottom: 8px; font-weight: 900;
  letter-spacing: 3px;
  text-shadow: 0 0 50px rgba(200,170,255,0.6), 0 0 120px rgba(200,170,255,0.2), 0 4px 24px rgba(0,0,0,0.5);
  animation: titleGlow 3s ease-in-out infinite;
}
@keyframes titleGlow {
  0%, 100% { filter: brightness(1); }
  50% { filter: brightness(1.15); }
}
#overlay p {
  color: rgba(210,220,230,0.9); font-size: 16px; margin-bottom: 28px;
  text-align: center; line-height: 1.8; max-width: 440px;
  text-shadow: 0 1px 4px rgba(0,0,0,0.6);
}
#overlay button {
  padding: 16px 56px; font-size: 19px; border: none; border-radius: 50px;
  background: linear-gradient(135deg, #e8c8ff 0%, #c8a0e8 50%, #dbb8f0 100%);
  color: #1a0a30; font-weight: 900; cursor: pointer;
  transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.25s;
  letter-spacing: 1.5px; text-transform: uppercase;
  box-shadow: 0 4px 24px rgba(200,170,255,0.45), 0 0 60px rgba(200,170,255,0.15);
  position: relative; overflow: hidden;
}
#overlay button::after {
  content: ''; position: absolute; top: -50%; left: -50%;
  width: 200%; height: 200%; border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
  opacity: 0; transition: opacity 0.3s;
}
#overlay button:hover {
  transform: scale(1.1) translateY(-2px);
  box-shadow: 0 8px 36px rgba(200,170,255,0.6), 0 0 80px rgba(200,170,255,0.25);
}
#overlay button:hover::after { opacity: 1; }

.power-bar-container {
  position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%);
  width: 340px; height: 28px; border-radius: 14px; z-index: 10;
  background: rgba(0,0,0,0.6); overflow: hidden;
  border: 1.5px solid rgba(255,255,255,0.12);
  backdrop-filter: blur(6px);
  box-shadow: 0 4px 20px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05);
}
.power-bar-fill {
  height: 100%; width: 0%; border-radius: 12px;
  background: linear-gradient(90deg, #c8a0ff 0%, #dbb8f0 25%, #f7dc6f 55%, #ffb87a 80%, #ff9a9a 100%);
  transition: width 0.05s;
  box-shadow: inset 0 1px 2px rgba(255,255,255,0.35), 0 0 15px rgba(200,170,255,0.3);
  position: relative;
}
.power-bar-fill::after {
  content: ''; position: absolute; right: 0; top: 0;
  width: 30px; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4));
  border-radius: 0 12px 12px 0;
}
.power-label {
  position: absolute; bottom: 64px; left: 50%; transform: translateX(-50%);
  color: #fff; font-size: 14px; font-weight: 700; z-index: 10; pointer-events: none;
  text-shadow: 0 2px 12px rgba(0,0,0,0.95), 0 0 30px rgba(0,0,0,0.4);
  white-space: nowrap; letter-spacing: 0.5px;
}
.tap-hint {
  position: absolute; bottom: 100px; left: 50%; transform: translateX(-50%);
  color: #ffe66d; font-size: 22px; font-weight: 900; z-index: 10; pointer-events: none;
  animation: tapPulse 0.6s ease-in-out infinite;
  text-shadow: 0 0 20px rgba(255,230,109,0.6), 0 2px 10px rgba(0,0,0,0.8);
  letter-spacing: 4px; text-transform: uppercase;
}
@keyframes tapPulse {
  0%,100% { opacity: 1; transform: translateX(-50%) scale(1); }
  50% { opacity: 0.6; transform: translateX(-50%) scale(1.12); }
}

/* Coin counter */
#coin-display {
  position: absolute; top: 12px; right: 16px;
  color: #ffd700; font-size: 18px; font-weight: 900; z-index: 10;
  display: flex; align-items: center; gap: 6px;
  text-shadow: 0 0 12px rgba(255,215,0,0.5), 0 2px 6px rgba(0,0,0,0.6);
  pointer-events: none;
}
#coin-display .coin-icon {
  width: 26px; height: 26px; border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #ffe066, #daa520, #b8860b);
  border: 2px solid #ffd700;
  box-shadow: 0 0 10px rgba(255,215,0,0.4), inset 0 -2px 4px rgba(0,0,0,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; color: #8b6914; font-weight: 900;
}
.coin-add {
  position: absolute; top: 12px; right: 60px;
  color: #ffd700; font-size: 20px; font-weight: 900; z-index: 11;
  pointer-events: none; animation: coinFloat 1.2s ease-out forwards;
  text-shadow: 0 0 10px rgba(255,215,0,0.6);
}
@keyframes coinFloat {
  0% { opacity: 1; transform: translateY(0); }
  100% { opacity: 0; transform: translateY(-40px); }
}

/* Secret found notification */
#secret-toast {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0);
  background: rgba(10,10,30,0.85); border: 2px solid rgba(200,160,255,0.5);
  border-radius: 16px; padding: 20px 36px; z-index: 15;
  text-align: center; backdrop-filter: blur(10px);
  transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), opacity 0.3s;
  opacity: 0; pointer-events: none;
  box-shadow: 0 0 40px rgba(160,100,255,0.3), 0 0 80px rgba(160,100,255,0.1);
}
#secret-toast.show {
  transform: translate(-50%, -50%) scale(1); opacity: 1;
}
#secret-toast h3 {
  color: #c8a0ff; font-size: 22px; margin-bottom: 6px;
  text-shadow: 0 0 20px rgba(200,160,255,0.5);
}
#secret-toast p {
  color: #ddd; font-size: 14px; line-height: 1.5;
}
#secret-toast .gift-coins {
  color: #ffd700; font-size: 18px; font-weight: 900; margin-top: 8px;
}

/* Stars display */
#stars-display {
  position: absolute; top: 40px; right: 16px;
  color: #c8a0ff; font-size: 14px; font-weight: 700; z-index: 10;
  pointer-events: none;
  text-shadow: 0 0 8px rgba(200,160,255,0.4);
}
#exclusive-display {
  position: absolute; top: 62px; right: 16px;
  color: #e070ff; font-size: 16px; font-weight: 900; z-index: 10;
  pointer-events: none;
  display: flex; align-items: center; gap: 7px;
  text-shadow: 0 0 14px rgba(200,80,255,0.7), 0 0 28px rgba(140,40,255,0.3);
}
#exclusive-display .excl-icon {
  width: 24px; height: 24px; position: relative;
  background: conic-gradient(from 0deg, #ff44ff, #aa44ff, #44ccff, #44ffaa, #ffdd44, #ff44ff);
  clip-path: polygon(50% 0%, 85% 25%, 100% 50%, 85% 75%, 50% 100%, 15% 75%, 0% 50%, 15% 25%);
  animation: exclSpin 4s linear infinite;
  filter: drop-shadow(0 0 6px rgba(200,80,255,0.7));
}
#exclusive-display .excl-icon::after {
  content: '';
  position: absolute; top: 3px; left: 3px; right: 3px; bottom: 3px;
  background: radial-gradient(circle at 35% 35%, rgba(255,255,255,0.9), rgba(200,120,255,0.6), rgba(100,40,200,0.8));
  clip-path: polygon(50% 0%, 85% 25%, 100% 50%, 85% 75%, 50% 100%, 15% 75%, 0% 50%, 15% 25%);
}
@keyframes exclSpin {
  0% { filter: drop-shadow(0 0 6px rgba(255,80,255,0.7)) hue-rotate(0deg); }
  50% { filter: drop-shadow(0 0 10px rgba(100,150,255,0.8)) hue-rotate(45deg); }
  100% { filter: drop-shadow(0 0 6px rgba(255,80,255,0.7)) hue-rotate(0deg); }
}
#exclusive-toast {
  position: absolute; top: 30%; left: 50%; transform: translate(-50%, -50%) scale(0);
  background: radial-gradient(ellipse at 40% 30%, rgba(80,20,120,0.96), rgba(20,0,40,0.98));
  border: 2px solid transparent;
  background-clip: padding-box;
  border-radius: 20px; padding: 28px 48px; z-index: 16;
  text-align: center; backdrop-filter: blur(16px);
  transition: transform 0.5s cubic-bezier(0.34,1.56,0.64,1), opacity 0.4s;
  opacity: 0; pointer-events: none;
  box-shadow:
    0 0 0 2px rgba(255,100,255,0.5),
    0 0 40px rgba(200,50,255,0.5),
    0 0 80px rgba(150,30,255,0.25),
    inset 0 0 40px rgba(200,80,255,0.1);
  overflow: hidden;
}
#exclusive-toast::before {
  content: '';
  position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
  background: conic-gradient(from 0deg, transparent 0%, rgba(255,100,255,0.15) 10%, transparent 20%,
    transparent 50%, rgba(100,150,255,0.15) 60%, transparent 70%);
  animation: toastShine 3s linear infinite;
}
@keyframes toastShine {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
#exclusive-toast.show {
  transform: translate(-50%, -50%) scale(1); opacity: 1;
}
#exclusive-toast .toast-diamond {
  width: 48px; height: 48px; margin: 0 auto 10px;
  background: conic-gradient(from 0deg, #ff44ff, #aa44ff, #44ccff, #44ffaa, #ffdd44, #ff44ff);
  clip-path: polygon(50% 0%, 85% 25%, 100% 50%, 85% 75%, 50% 100%, 15% 75%, 0% 50%, 15% 25%);
  animation: exclSpin 3s linear infinite;
  position: relative;
  filter: drop-shadow(0 0 12px rgba(200,80,255,0.8));
}
#exclusive-toast .toast-diamond::after {
  content: ''; position: absolute;
  top: 5px; left: 5px; right: 5px; bottom: 5px;
  background: radial-gradient(circle at 35% 30%, rgba(255,255,255,0.95), rgba(220,140,255,0.6), rgba(120,50,220,0.9));
  clip-path: polygon(50% 0%, 85% 25%, 100% 50%, 85% 75%, 50% 100%, 15% 75%, 0% 50%, 15% 25%);
}
#exclusive-toast h3 {
  color: #eeb0ff; font-size: 22px; margin-bottom: 4px;
  text-shadow: 0 0 20px rgba(200,100,255,0.6);
  position: relative;
  letter-spacing: 1px;
}
#exclusive-toast p {
  color: rgba(220,180,255,0.85); font-size: 13px;
  position: relative;
  letter-spacing: 0.5px;
}
.shop-item.exclusive-item {
  border-color: rgba(200,100,255,0.25);
  background: linear-gradient(135deg, rgba(80,0,120,0.12), rgba(40,0,80,0.2));
}
.shop-item.exclusive-item:hover {
  border-color: rgba(200,100,255,0.5);
  background: linear-gradient(135deg, rgba(100,20,160,0.2), rgba(60,0,120,0.3));
  box-shadow: 0 0 20px rgba(200,80,255,0.15);
}
.shop-item.exclusive-item .item-price {
  color: #dd88ff;
}
.excl-price-icon {
  display: inline-block; width: 14px; height: 14px;
  background: conic-gradient(from 0deg, #ff44ff, #aa44ff, #44ccff, #44ffaa, #ffdd44, #ff44ff);
  clip-path: polygon(50% 0%, 85% 25%, 100% 50%, 85% 75%, 50% 100%, 15% 75%, 0% 50%, 15% 25%);
  vertical-align: middle; margin-right: 3px;
  filter: drop-shadow(0 0 3px rgba(200,80,255,0.6));
  animation: exclSpin 4s linear infinite;
}
.coin-price-icon {
  display: inline-block; width: 14px; height: 14px;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #ffe066, #daa520, #b8860b);
  border: 1.5px solid #ffd700;
  vertical-align: middle; margin-right: 3px;
  box-shadow: 0 0 4px rgba(255,215,0,0.4);
}

/* Secret hint */
#secret-hint {
  position: absolute; top: 50%; right: 12px; transform: translateY(-50%);
  color: rgba(200,160,255,0.6); font-size: 11px; font-weight: 700; z-index: 10;
  pointer-events: none; writing-mode: vertical-rl; letter-spacing: 1px;
  text-shadow: 0 0 8px rgba(200,160,255,0.3);
  opacity: 0; transition: opacity 0.5s;
}
#secret-hint.visible { opacity: 1; }

/* Shop */
#shop-btn {
  padding: 10px 32px; font-size: 15px; border: none; border-radius: 50px;
  background: linear-gradient(135deg, #ffd700 0%, #ffaa00 100%);
  color: #3a2000; font-weight: 900; cursor: pointer; margin-top: 12px;
  letter-spacing: 1px; text-transform: uppercase;
  box-shadow: 0 3px 16px rgba(255,215,0,0.35);
  transition: transform 0.2s, box-shadow 0.2s;
}
#shop-btn:hover { transform: scale(1.08); box-shadow: 0 5px 24px rgba(255,215,0,0.5); }

#shop-panel {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  display: none; justify-content: center; align-items: center;
  background: radial-gradient(ellipse at 50% 40%, rgba(20,10,40,0.92) 0%, rgba(5,2,15,0.96) 100%);
  z-index: 25; flex-direction: column;
  backdrop-filter: blur(14px);
}
#shop-panel.open { display: flex; }
#shop-panel h2 {
  color: #ffd700; font-size: 32px; font-weight: 900; margin-bottom: 6px;
  text-shadow: 0 0 30px rgba(255,215,0,0.4);
  letter-spacing: 3px;
}
#shop-coins {
  color: #ffd700; font-size: 16px; font-weight: 700; margin-bottom: 18px;
  text-shadow: 0 0 10px rgba(255,215,0,0.3);
}
#shop-grid {
  display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px;
  max-width: 640px; width: 94%;
  max-height: 65vh; overflow-y: auto; padding: 12px 8px;
  scrollbar-width: thin; scrollbar-color: rgba(200,160,255,0.3) transparent;
}
#shop-grid::-webkit-scrollbar { width: 8px; }
#shop-grid::-webkit-scrollbar-track { background: rgba(20,10,40,0.3); border-radius: 4px; }
#shop-grid::-webkit-scrollbar-thumb { background: rgba(200,160,255,0.4); border-radius: 4px; }
.shop-item {
  background: linear-gradient(160deg, rgba(255,255,255,0.08) 0%, rgba(120,80,200,0.07) 40%, rgba(60,30,120,0.05) 100%);
  border: 1px solid rgba(160,130,220,0.18);
  border-radius: 22px; padding: 20px 14px 16px; text-align: center;
  cursor: pointer; transition: transform 0.3s cubic-bezier(.22,.68,0,1.2), border-color 0.3s, box-shadow 0.4s;
  position: relative; overflow: hidden;
  min-height: 270px;
  backdrop-filter: blur(12px);
  box-shadow: 0 2px 12px rgba(0,0,0,0.15), inset 0 1px 0 rgba(255,255,255,0.06);
}
.shop-item::before {
  content: ''; position: absolute; top: 0; left: 15%; right: 15%; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
}
.shop-item::after {
  content: ''; position: absolute; inset: 0; border-radius: 22px; pointer-events: none;
  background: radial-gradient(ellipse at 50% 0%, rgba(200,180,255,0.05) 0%, transparent 60%);
}
.shop-item:hover {
  transform: translateY(-6px) scale(1.03);
  border-color: rgba(200,170,255,0.45);
  box-shadow: 0 14px 40px rgba(80,40,160,0.2), 0 0 0 1px rgba(200,170,255,0.1), inset 0 1px 0 rgba(255,255,255,0.08);
}
.shop-item.owned { border-color: rgba(100,255,160,0.25); }
.shop-item.owned:hover { transform: none; box-shadow: 0 2px 12px rgba(0,0,0,0.15); }
.shop-item.active {
  border-color: rgba(255,215,0,0.4);
  box-shadow: 0 0 32px rgba(255,215,0,0.12), 0 0 0 1px rgba(255,215,0,0.15), inset 0 0 24px rgba(255,215,0,0.03);
}
.shop-item .item-icon {
  width: 140px; height: 140px; margin: 0 auto 14px;
  filter: drop-shadow(0 6px 18px rgba(0,0,0,0.4));
}
.shop-item .item-icon canvas {
  width: 100%; height: 100%; display: block;
}
.shop-item .item-name {
  color: #f0e0ff; font-size: 16px; font-weight: 800; margin-bottom: 4px;
  letter-spacing: 0.4px; text-shadow: 0 1px 4px rgba(0,0,0,0.3);
}
.shop-item .item-desc {
  color: rgba(255,255,255,0.5); font-size: 12px; line-height: 1.4;
  margin-bottom: 10px; min-height: 32px;
}
.shop-item .item-price { color: #ffd700; font-size: 15px; font-weight: 800; }
.shop-item .item-price.owned-label { color: #66ffaa; }
.shop-item .item-status { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 4px; }
.shop-divider {
  grid-column: 1 / -1;
  display: flex; align-items: center; gap: 14px;
  padding: 10px 0 6px;
}
.shop-divider .divider-line {
  flex: 1; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(200,160,255,0.4), transparent);
}
.shop-divider .divider-label {
  font-size: 14px; font-weight: 900; letter-spacing: 2px; white-space: nowrap;
}
.shop-divider.regular .divider-label {
  color: #ffd700;
  text-shadow: 0 0 12px rgba(255,215,0,0.4);
}
.shop-divider.exclusive .divider-label {
  color: #dd88ff;
  text-shadow: 0 0 12px rgba(200,80,255,0.5);
}
.shop-divider.exclusive .divider-line {
  background: linear-gradient(90deg, transparent, rgba(200,80,255,0.4), transparent);
}
#shop-close {
  margin-top: 18px; padding: 10px 40px; font-size: 15px; border: none;
  border-radius: 50px; background: rgba(255,255,255,0.08); color: #ccc;
  font-weight: 700; cursor: pointer; letter-spacing: 1px;
  transition: background 0.2s;
}
#shop-close:hover { background: rgba(255,255,255,0.15); }
#shop-msg {
  color: #ff6b6b; font-size: 13px; font-weight: 700; margin-top: 8px;
  min-height: 18px; text-shadow: 0 0 8px rgba(255,100,100,0.3);
  transition: opacity 0.3s;
}
</style>
</head>
<body>

<div id="container">
  <div id="ui">
    <h2 id="tournament-name">Tournament 1</h2>
    <div class="info">
      <span id="hole-label">Hole 1/3</span> &nbsp;&bull;&nbsp;
      <span id="strokes-label">Strokes: 0</span> &nbsp;&bull;&nbsp;
      <span id="par-label">Par: 3</span>
    </div>
    <div class="info" style="margin-top:4px;">
      <span id="total-score">Total: 0</span> &nbsp;&bull;&nbsp;
      <span id="wins-label">Wins: 0</span>
    </div>
  </div>

  <div id="vignette"></div>
  <div class="power-label" id="power-label">Click to aim, then TAP to build power!</div>
  <div class="tap-hint hidden" id="tap-hint">⚡ TAP TAP TAP! ⚡</div>
  <div class="power-bar-container hidden" id="power-bar">
    <div class="power-bar-fill" id="power-fill"></div>
  </div>

  <div id="overlay">
    <div class="menu-backdrop">
      <div class="menu-firefly f1"></div>
      <div class="menu-firefly f2"></div>
      <div class="menu-firefly f3"></div>
      <div class="menu-firefly f4"></div>
      <div class="menu-pond"></div>
    </div>
    <h1 id="overlay-title">🌙 Twilight Golf</h1>
    <p id="overlay-text">Aim with your mouse, then tap gently to build power.<br>Press <b>Space</b> or <b>Right-click</b> to putt.<br>Take your time. Enjoy the scenery.<br><span style="color:#c8a0ff">Each course hides a secret... explore at your own pace.</span></p>
    <button id="overlay-btn" onclick="startGame()">Begin</button>
    <button id="shop-btn" onclick="openShop()">🛒 Shop</button>
  </div>

  <div id="shop-panel">
    <h2>🛍️ Shop</h2>
    <div id="shop-coins">Your coins: <span id="shop-coin-count">0</span> &nbsp;|&nbsp; <span style="color:#ff66ff">💎 <span id="shop-excl-count">0</span></span></div>
    <div id="shop-grid"></div>
    <div id="shop-msg"></div>
    <button id="shop-close" onclick="closeShop()">Back</button>
  </div>

  <div id="coin-display"><div class="coin-icon">$</div><span id="coin-count">0</span></div>
  <div id="stars-display">⭐ <span id="star-count">0</span></div>
  <div id="exclusive-display"><div class="excl-icon"></div><span id="exclusive-count">0</span></div>
  <div id="exclusive-toast"><div class="toast-diamond"></div><h3>Exclusive Coin!</h3><p>All lights in one shot!</p></div>
  <div id="secret-toast"><h3 id="secret-title">🎁 Secret Found!</h3><p id="secret-desc"></p><div class="gift-coins" id="secret-reward"></div></div>
  <div id="secret-hint"></div>
</div>

<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.163.0/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.163.0/examples/jsm/"
  }
}
</script>

<script type="module">
import * as THREE from 'three';

// ---- Audio System (Web Audio API - all procedural) ----
const AudioCtx = window.AudioContext || window.webkitAudioContext;
let audioCtx = null;
let musicGain = null;
let sfxGain = null;
let musicPlaying = false;
let musicNodes = [];

function initAudio() {
  if (audioCtx) return;
  if (!AudioCtx) return;
  audioCtx = new AudioCtx();
  // Master gains
  musicGain = audioCtx.createGain();
  musicGain.gain.value = 0.35;
  musicGain.connect(audioCtx.destination);
  sfxGain = audioCtx.createGain();
  sfxGain.gain.value = 0.5;
  sfxGain.connect(audioCtx.destination);
}

// --- Background Music (procedural ambient loop) ---
function startMusic() {
  if (musicPlaying) return;
  musicPlaying = true;
  playMusicLoop();
}

function playMusicLoop() {
  if (!audioCtx || !musicPlaying) return;
  // Ambient chord pad
  const chords = [
    [261.6, 329.6, 392.0],  // C major
    [220.0, 277.2, 329.6],  // A minor
    [246.9, 311.1, 370.0],  // B dim-ish
    [196.0, 246.9, 293.7],  // G major
    [174.6, 220.0, 261.6],  // F major
    [220.0, 261.6, 329.6],  // Am
  ];
  const now = audioCtx.currentTime;
  const chordDur = 4.0;
  const totalDur = chords.length * chordDur;

  chords.forEach((notes, ci) => {
    const start = now + ci * chordDur;
    notes.forEach(freq => {
      // Soft pad oscillator
      const osc = audioCtx.createOscillator();
      osc.type = 'sine';
      osc.frequency.value = freq;
      const osc2 = audioCtx.createOscillator();
      osc2.type = 'triangle';
      osc2.frequency.value = freq * 1.002; // slight detune for warmth
      const g = audioCtx.createGain();
      g.gain.setValueAtTime(0, start);
      g.gain.linearRampToValueAtTime(0.06, start + 0.8);
      g.gain.setValueAtTime(0.06, start + chordDur - 1.0);
      g.gain.linearRampToValueAtTime(0, start + chordDur);
      osc.connect(g); osc2.connect(g); g.connect(musicGain);
      osc.start(start); osc2.start(start);
      osc.stop(start + chordDur + 0.1);
      osc2.stop(start + chordDur + 0.1);
      musicNodes.push(osc, osc2);
    });
    // Soft high note melody
    const melodyNote = notes[Math.floor(Math.random() * notes.length)] * 2;
    const mOsc = audioCtx.createOscillator();
    mOsc.type = 'sine';
    mOsc.frequency.value = melodyNote;
    const mG = audioCtx.createGain();
    mG.gain.setValueAtTime(0, start + 1.0);
    mG.gain.linearRampToValueAtTime(0.03, start + 1.5);
    mG.gain.linearRampToValueAtTime(0, start + 3.0);
    mOsc.connect(mG); mG.connect(musicGain);
    mOsc.start(start + 1.0); mOsc.stop(start + 3.2);
    musicNodes.push(mOsc);
  });

  // Schedule next loop
  setTimeout(() => {
    musicNodes = [];
    if (musicPlaying) playMusicLoop();
  }, totalDur * 1000 - 200);
}

function stopMusic() {
  musicPlaying = false;
  musicNodes.forEach(n => { try { n.stop(); } catch(e) {} });
  musicNodes = [];
}

// --- Ambient Nature Sounds (crickets + soft wind, looping) ---
let naturePlaying = false;
let natureNodes = [];

function startNatureSounds() {
  if (naturePlaying || !audioCtx) return;
  naturePlaying = true;
  playNatureLoop();
}

function playNatureLoop() {
  if (!audioCtx || !naturePlaying) return;
  const now = audioCtx.currentTime;
  const loopDur = 8;

  // Gentle wind (filtered noise)
  const windBufSize = Math.floor(audioCtx.sampleRate * loopDur);
  const windBuf = audioCtx.createBuffer(1, windBufSize, audioCtx.sampleRate);
  const windData = windBuf.getChannelData(0);
  for (let i = 0; i < windBufSize; i++) {
    const t = i / audioCtx.sampleRate;
    windData[i] = (Math.random() * 2 - 1) * 0.015 * (0.5 + Math.sin(t * 0.3) * 0.3);
  }
  const windSrc = audioCtx.createBufferSource();
  windSrc.buffer = windBuf;
  const windLP = audioCtx.createBiquadFilter();
  windLP.type = 'lowpass'; windLP.frequency.value = 400;
  const windGain = audioCtx.createGain();
  windGain.gain.setValueAtTime(0, now);
  windGain.gain.linearRampToValueAtTime(0.6, now + 2);
  windGain.gain.setValueAtTime(0.6, now + loopDur - 2);
  windGain.gain.linearRampToValueAtTime(0, now + loopDur);
  windSrc.connect(windLP); windLP.connect(windGain); windGain.connect(musicGain);
  windSrc.start(now); windSrc.stop(now + loopDur + 0.1);
  natureNodes.push(windSrc);

  // Cricket chirps (random short high-pitched sine bursts)
  const numChirps = 8 + Math.floor(Math.random() * 6);
  for (let c = 0; c < numChirps; c++) {
    const chirpTime = now + 0.5 + Math.random() * (loopDur - 1);
    const chirpFreq = 3800 + Math.random() * 1500;
    const chirpDur = 0.04 + Math.random() * 0.06;
    const numPulses = 2 + Math.floor(Math.random() * 4);
    for (let p = 0; p < numPulses; p++) {
      const pt = chirpTime + p * (chirpDur + 0.02);
      const co = audioCtx.createOscillator();
      co.type = 'sine'; co.frequency.value = chirpFreq + (Math.random() - 0.5) * 200;
      const cg = audioCtx.createGain();
      cg.gain.setValueAtTime(0, pt);
      cg.gain.linearRampToValueAtTime(0.012, pt + chirpDur * 0.2);
      cg.gain.setValueAtTime(0.012, pt + chirpDur * 0.8);
      cg.gain.linearRampToValueAtTime(0, pt + chirpDur);
      co.connect(cg); cg.connect(musicGain);
      co.start(pt); co.stop(pt + chirpDur + 0.01);
      natureNodes.push(co);
    }
  }

  setTimeout(() => {
    natureNodes = [];
    if (naturePlaying) playNatureLoop();
  }, loopDur * 1000 - 300);
}

function stopNatureSounds() {
  naturePlaying = false;
  natureNodes.forEach(n => { try { n.stop(); } catch(e) {} });
  natureNodes = [];
}

// --- Sound Effects ---
function playSwingSound() {
  if (!audioCtx) return;
  // Whoosh sound
  const bufferSize = audioCtx.sampleRate * 0.3;
  const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
  const data = buffer.getChannelData(0);
  for (let i = 0; i < bufferSize; i++) {
    const t = i / audioCtx.sampleRate;
    data[i] = (Math.random() * 2 - 1) * Math.exp(-t * 12) * 0.3;
  }
  const src = audioCtx.createBufferSource();
  src.buffer = buffer;
  // Bandpass for whoosh character
  const bp = audioCtx.createBiquadFilter();
  bp.type = 'bandpass';
  bp.frequency.value = 800;
  bp.frequency.linearRampToValueAtTime(2000, audioCtx.currentTime + 0.15);
  bp.Q.value = 1.5;
  src.connect(bp); bp.connect(sfxGain);
  src.start();
}

function playHitSound() {
  if (!audioCtx) return;
  const now = audioCtx.currentTime;
  // Sharp impact
  const osc = audioCtx.createOscillator();
  osc.type = 'sine';
  osc.frequency.setValueAtTime(600, now);
  osc.frequency.exponentialRampToValueAtTime(150, now + 0.15);
  const g = audioCtx.createGain();
  g.gain.setValueAtTime(0.6, now);
  g.gain.exponentialRampToValueAtTime(0.001, now + 0.2);
  osc.connect(g); g.connect(sfxGain);
  osc.start(now); osc.stop(now + 0.25);
  // Click layer
  const bufSize = audioCtx.sampleRate * 0.05;
  const buf = audioCtx.createBuffer(1, bufSize, audioCtx.sampleRate);
  const d = buf.getChannelData(0);
  for (let i = 0; i < bufSize; i++) {
    const t = i / audioCtx.sampleRate;
    d[i] = (Math.random() * 2 - 1) * Math.exp(-t * 80) * 0.4;
  }
  const s = audioCtx.createBufferSource();
  s.buffer = buf;
  const hpf = audioCtx.createBiquadFilter();
  hpf.type = 'highpass'; hpf.frequency.value = 2000;
  s.connect(hpf); hpf.connect(sfxGain);
  s.start(now);
}

function playBounceSound(intensity) {
  if (!audioCtx) return;
  const now = audioCtx.currentTime;
  const vol = Math.min(intensity * 3, 0.5);
  if (vol < 0.02) return;
  const osc = audioCtx.createOscillator();
  osc.type = 'sine';
  osc.frequency.setValueAtTime(300 + intensity * 600, now);
  osc.frequency.exponentialRampToValueAtTime(100, now + 0.12);
  const g = audioCtx.createGain();
  g.gain.setValueAtTime(vol, now);
  g.gain.exponentialRampToValueAtTime(0.001, now + 0.15);
  osc.connect(g); g.connect(sfxGain);
  osc.start(now); osc.stop(now + 0.2);
}

function playWallBounceSound(intensity) {
  if (!audioCtx) return;
  const now = audioCtx.currentTime;
  const vol = Math.min(intensity * 3, 0.45);
  if (vol < 0.02) return;
  // Wooden thud
  const osc = audioCtx.createOscillator();
  osc.type = 'triangle';
  osc.frequency.setValueAtTime(200 + intensity * 300, now);
  osc.frequency.exponentialRampToValueAtTime(80, now + 0.1);
  const g = audioCtx.createGain();
  g.gain.setValueAtTime(vol, now);
  g.gain.exponentialRampToValueAtTime(0.001, now + 0.12);
  osc.connect(g); g.connect(sfxGain);
  osc.start(now); osc.stop(now + 0.15);
}

function playTapSound() {
  if (!audioCtx) return;
  const now = audioCtx.currentTime;
  const osc = audioCtx.createOscillator();
  osc.type = 'sine';
  const pitch = 500 + power * 6; // pitch rises with power
  osc.frequency.setValueAtTime(pitch, now);
  osc.frequency.setValueAtTime(pitch * 1.2, now + 0.03);
  const g = audioCtx.createGain();
  g.gain.setValueAtTime(0.15, now);
  g.gain.exponentialRampToValueAtTime(0.001, now + 0.08);
  osc.connect(g); g.connect(sfxGain);
  osc.start(now); osc.stop(now + 0.1);
}

function playHoleSound() {
  if (!audioCtx) return;
  const now = audioCtx.currentTime;
  // Ball dropping in hole
  const osc1 = audioCtx.createOscillator();
  osc1.type = 'sine';
  osc1.frequency.setValueAtTime(400, now);
  osc1.frequency.exponentialRampToValueAtTime(80, now + 0.3);
  const g1 = audioCtx.createGain();
  g1.gain.setValueAtTime(0.4, now);
  g1.gain.exponentialRampToValueAtTime(0.001, now + 0.35);
  osc1.connect(g1); g1.connect(sfxGain);
  osc1.start(now); osc1.stop(now + 0.4);
  // Victory jingle — ascending notes
  const notes = [523.3, 659.3, 784.0, 1047]; // C5, E5, G5, C6
  notes.forEach((freq, i) => {
    const t = now + 0.2 + i * 0.15;
    const o = audioCtx.createOscillator();
    o.type = 'sine';
    o.frequency.value = freq;
    const gn = audioCtx.createGain();
    gn.gain.setValueAtTime(0, t);
    gn.gain.linearRampToValueAtTime(0.25, t + 0.05);
    gn.gain.exponentialRampToValueAtTime(0.001, t + 0.4);
    o.connect(gn); gn.connect(sfxGain);
    o.start(t); o.stop(t + 0.45);
  });
  // Final shimmer
  const shimmer = audioCtx.createOscillator();
  shimmer.type = 'sine';
  shimmer.frequency.value = 1047;
  const sg = audioCtx.createGain();
  sg.gain.setValueAtTime(0, now + 0.8);
  sg.gain.linearRampToValueAtTime(0.15, now + 0.9);
  sg.gain.exponentialRampToValueAtTime(0.001, now + 1.8);
  shimmer.connect(sg); sg.connect(sfxGain);
  shimmer.start(now + 0.8); shimmer.stop(now + 2.0);
}

function playWinSound() {
  if (!audioCtx) return;
  const now = audioCtx.currentTime;
  // Triumphant fanfare
  const fanfare = [523.3, 659.3, 784.0, 1047, 1047];
  const durations = [0.2, 0.2, 0.2, 0.15, 0.5];
  let t = now;
  fanfare.forEach((freq, i) => {
    const o = audioCtx.createOscillator();
    o.type = i < 3 ? 'triangle' : 'sine';
    o.frequency.value = freq;
    const g = audioCtx.createGain();
    g.gain.setValueAtTime(0, t);
    g.gain.linearRampToValueAtTime(0.3, t + 0.04);
    g.gain.setValueAtTime(0.3, t + durations[i] * 0.7);
    g.gain.linearRampToValueAtTime(0.001, t + durations[i]);
    o.connect(g); g.connect(sfxGain);
    o.start(t); o.stop(t + durations[i] + 0.05);
    t += durations[i];
  });
}

function playLoseSound() {
  if (!audioCtx) return;
  const now = audioCtx.currentTime;
  // Descending sad tones
  const notes = [392, 349.2, 293.7, 261.6];
  notes.forEach((freq, i) => {
    const t = now + i * 0.25;
    const o = audioCtx.createOscillator();
    o.type = 'triangle';
    o.frequency.value = freq;
    const g = audioCtx.createGain();
    g.gain.setValueAtTime(0, t);
    g.gain.linearRampToValueAtTime(0.2, t + 0.05);
    g.gain.exponentialRampToValueAtTime(0.001, t + 0.35);
    o.connect(g); g.connect(sfxGain);
    o.start(t); o.stop(t + 0.4);
  });
}

let lastRollSoundTime = 0;
function playRollSound(speed) {
  if (!audioCtx) return;
  const now = Date.now();
  if (now - lastRollSoundTime < 80) return; // throttle
  if (speed < 0.02) return;
  lastRollSoundTime = now;
  const t = audioCtx.currentTime;
  const bufSize = Math.floor(audioCtx.sampleRate * 0.04);
  const buf = audioCtx.createBuffer(1, bufSize, audioCtx.sampleRate);
  const d = buf.getChannelData(0);
  for (let i = 0; i < bufSize; i++) {
    d[i] = (Math.random() * 2 - 1) * 0.02 * speed * 8;
  }
  const s = audioCtx.createBufferSource();
  s.buffer = buf;
  const lp = audioCtx.createBiquadFilter();
  lp.type = 'lowpass';
  lp.frequency.value = 400 + speed * 2000;
  s.connect(lp); lp.connect(sfxGain);
  s.start();
}

// ---- Three.js Setup ----
const container = document.getElementById('container');
const renderer = new THREE.WebGLRenderer({ antialias: true, powerPreference: 'high-performance' });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.1;
renderer.outputColorSpace = THREE.SRGBColorSpace;
container.insertBefore(renderer.domElement, container.firstChild);

const scene = new THREE.Scene();

// ---- Sky Dome (hemisphere wrapping the scene) ----
const skyCanvas = document.createElement('canvas');
skyCanvas.width = 2048; skyCanvas.height = 1024;
const skyCtx = skyCanvas.getContext('2d');

// Base gradient — dreamy twilight sky (deep indigo → purple → rose → warm gold at horizon)
const skyGrad = skyCtx.createLinearGradient(0, 0, 0, 1024);
skyGrad.addColorStop(0, '#05051a');
skyGrad.addColorStop(0.06, '#0a0830');
skyGrad.addColorStop(0.15, '#120f45');
skyGrad.addColorStop(0.28, '#1e1260');
skyGrad.addColorStop(0.40, '#3a1878');
skyGrad.addColorStop(0.52, '#6a2088');
skyGrad.addColorStop(0.62, '#9a3070');
skyGrad.addColorStop(0.72, '#c84860');
skyGrad.addColorStop(0.80, '#e87050');
skyGrad.addColorStop(0.88, '#f0a050');
skyGrad.addColorStop(0.94, '#f8c870');
skyGrad.addColorStop(1.0, '#ffe0a0');
skyCtx.fillStyle = skyGrad;
skyCtx.fillRect(0, 0, 2048, 1024);

// ---- Stars (twinkling in upper sky) ----
for (let i = 0; i < 300; i++) {
  const sx = Math.random() * 2048;
  const sy = Math.random() * 550; // only upper portion
  const sr = 0.3 + Math.random() * 1.5;
  const brightness = 0.3 + Math.random() * 0.7;
  const starGrad = skyCtx.createRadialGradient(sx, sy, 0, sx, sy, sr * 3);
  starGrad.addColorStop(0, `rgba(255,255,255,${brightness})`);
  starGrad.addColorStop(0.3, `rgba(220,230,255,${brightness * 0.4})`);
  starGrad.addColorStop(1, 'rgba(200,210,255,0)');
  skyCtx.fillStyle = starGrad;
  skyCtx.fillRect(sx - sr * 3, sy - sr * 3, sr * 6, sr * 6);
}
// A few brighter stars with cross-shaped twinkle
for (let i = 0; i < 12; i++) {
  const sx = 50 + Math.random() * 1950;
  const sy = 30 + Math.random() * 380;
  const br = 0.85 + Math.random() * 0.15;
  // Horizontal streak
  const h1 = skyCtx.createRadialGradient(sx, sy, 0, sx, sy, 8);
  h1.addColorStop(0, `rgba(255,255,255,${br})`);
  h1.addColorStop(1, 'rgba(255,255,255,0)');
  skyCtx.save(); skyCtx.translate(sx, sy); skyCtx.scale(3, 0.3);
  skyCtx.fillStyle = h1; skyCtx.fillRect(-8, -8, 16, 16);
  skyCtx.restore();
  // Vertical streak
  skyCtx.save(); skyCtx.translate(sx, sy); skyCtx.scale(0.3, 3);
  skyCtx.fillStyle = h1; skyCtx.fillRect(-8, -8, 16, 16);
  skyCtx.restore();
  // Core
  const core = skyCtx.createRadialGradient(sx, sy, 0, sx, sy, 2);
  core.addColorStop(0, `rgba(255,255,255,${br})`);
  core.addColorStop(1, 'rgba(255,255,255,0)');
  skyCtx.fillStyle = core; skyCtx.fillRect(sx - 2, sy - 2, 4, 4);
}

// ---- Moon (crescent, upper left area) ----
const moonX = 400, moonY = 200;
// Outer glow
for (let gl = 0; gl < 3; gl++) {
  const gr = [90, 55, 30][gl];
  const ga = [0.06, 0.1, 0.2][gl];
  const mg = skyCtx.createRadialGradient(moonX, moonY, 0, moonX, moonY, gr);
  mg.addColorStop(0, `rgba(220,210,255,${ga})`);
  mg.addColorStop(0.5, `rgba(180,170,230,${ga * 0.3})`);
  mg.addColorStop(1, 'rgba(150,140,200,0)');
  skyCtx.fillStyle = mg;
  skyCtx.fillRect(moonX - gr, moonY - gr, gr * 2, gr * 2);
}
// Moon disc
skyCtx.beginPath(); skyCtx.arc(moonX, moonY, 22, 0, Math.PI * 2);
const moonFill = skyCtx.createRadialGradient(moonX - 3, moonY - 3, 0, moonX, moonY, 22);
moonFill.addColorStop(0, 'rgba(255,250,240,0.95)');
moonFill.addColorStop(0.7, 'rgba(230,220,210,0.9)');
moonFill.addColorStop(1, 'rgba(200,190,180,0.7)');
skyCtx.fillStyle = moonFill; skyCtx.fill();
// Dark side (crescent effect)
skyCtx.beginPath(); skyCtx.arc(moonX + 10, moonY - 3, 20, 0, Math.PI * 2);
const darkSide = skyCtx.createRadialGradient(moonX + 10, moonY - 3, 0, moonX + 10, moonY - 3, 20);
darkSide.addColorStop(0, 'rgba(18,15,50,0.9)');
darkSide.addColorStop(0.8, 'rgba(18,15,50,0.7)');
darkSide.addColorStop(1, 'rgba(18,15,50,0)');
skyCtx.fillStyle = darkSide; skyCtx.fill();

// ---- Aurora Borealis (shimmering curtains) ----
function drawAurora(startX, width, peakY, colors, opacity) {
  for (let c = 0; c < colors.length; c++) {
    const [r, g, b] = colors[c];
    for (let x = startX; x < startX + width; x += 3) {
      const wave1 = Math.sin((x - startX) * 0.008 + c * 0.5) * 60;
      const wave2 = Math.sin((x - startX) * 0.015 + c * 1.2) * 30;
      const wave3 = Math.sin((x - startX) * 0.003) * 40;
      const cy = peakY + wave1 + wave2 + wave3;
      const h = 60 + Math.sin((x - startX) * 0.01) * 40;
      const ag = skyCtx.createLinearGradient(x, cy - h, x, cy + h);
      const a = opacity * (0.5 + Math.sin((x - startX) * 0.012 + c) * 0.3);
      ag.addColorStop(0, `rgba(${r},${g},${b},0)`);
      ag.addColorStop(0.3, `rgba(${r},${g},${b},${a * 0.6})`);
      ag.addColorStop(0.5, `rgba(${r},${g},${b},${a})`);
      ag.addColorStop(0.7, `rgba(${r},${g},${b},${a * 0.6})`);
      ag.addColorStop(1, `rgba(${r},${g},${b},0)`);
      skyCtx.fillStyle = ag;
      skyCtx.fillRect(x, cy - h, 4, h * 2);
    }
  }
}
drawAurora(200, 800, 280, [[80, 255, 180], [100, 200, 255], [150, 100, 255]], 0.08);
drawAurora(900, 700, 320, [[80, 200, 255], [180, 100, 255], [255, 100, 200]], 0.06);

// ---- Soft clouds (twilight-lit, warm tones) ----
function drawCloud(cx, cy, w, h, opacity) {
  const numBlobs = 6 + Math.floor(Math.random() * 5);
  for (let i = 0; i < numBlobs; i++) {
    const bx = cx + (Math.random() - 0.5) * w;
    const by = cy + (Math.random() - 0.5) * h * 0.6;
    const br = 15 + Math.random() * w * 0.2;
    // Warm-lit cloud
    const cg = skyCtx.createRadialGradient(bx, by, 0, bx, by, br);
    cg.addColorStop(0, `rgba(200,160,180,${opacity * 0.5})`);
    cg.addColorStop(0.4, `rgba(180,130,160,${opacity * 0.25})`);
    cg.addColorStop(0.7, `rgba(120,80,130,${opacity * 0.08})`);
    cg.addColorStop(1, 'rgba(100,60,110,0)');
    skyCtx.fillStyle = cg;
    skyCtx.fillRect(bx - br, by - br, br * 2, br * 2);
  }
}
drawCloud(300, 550, 200, 50, 0.7);
drawCloud(700, 520, 180, 45, 0.55);
drawCloud(1200, 560, 220, 55, 0.6);
drawCloud(1600, 530, 160, 40, 0.5);
drawCloud(500, 600, 140, 35, 0.4);
drawCloud(1000, 580, 170, 40, 0.45);
drawCloud(1800, 570, 130, 35, 0.35);

// ---- Warm horizon glow ----
const horizGlow = skyCtx.createLinearGradient(0, 750, 0, 1024);
horizGlow.addColorStop(0, 'rgba(255,200,120,0)');
horizGlow.addColorStop(0.3, 'rgba(255,180,100,0.1)');
horizGlow.addColorStop(0.6, 'rgba(255,160,80,0.15)');
horizGlow.addColorStop(1, 'rgba(255,220,160,0.08)');
skyCtx.fillStyle = horizGlow;
skyCtx.fillRect(0, 750, 2048, 274);

// Distant mountain silhouette (darker, more mysterious)
skyCtx.fillStyle = 'rgba(20,15,40,0.25)';
skyCtx.beginPath();
const mtnSeed = [0, 180, 320, 500, 620, 780, 950, 1100, 1280, 1440, 1600, 1750, 1920, 2048];
const mtnH = [870, 835, 815, 830, 800, 820, 805, 838, 815, 795, 825, 810, 835, 870];
for (let i = 0; i < mtnSeed.length; i++) {
  if (i === 0) skyCtx.moveTo(mtnSeed[i], mtnH[i]);
  else {
    const cpx = (mtnSeed[i - 1] + mtnSeed[i]) / 2;
    skyCtx.quadraticCurveTo(cpx, mtnH[i] - 18, mtnSeed[i], mtnH[i]);
  }
}
skyCtx.lineTo(2048, 1024); skyCtx.lineTo(0, 1024); skyCtx.closePath();
skyCtx.fill();
// Mountain rim light (warm sunset glow on peaks)
skyCtx.strokeStyle = 'rgba(255,150,80,0.12)';
skyCtx.lineWidth = 2;
skyCtx.beginPath();
for (let i = 0; i < mtnSeed.length; i++) {
  if (i === 0) skyCtx.moveTo(mtnSeed[i], mtnH[i]);
  else {
    const cpx = (mtnSeed[i - 1] + mtnSeed[i]) / 2;
    skyCtx.quadraticCurveTo(cpx, mtnH[i] - 18, mtnSeed[i], mtnH[i]);
  }
}
skyCtx.stroke();

const skyTexture = new THREE.CanvasTexture(skyCanvas);
skyTexture.magFilter = THREE.LinearFilter;
skyTexture.minFilter = THREE.LinearMipmapLinearFilter;

// Create a sky dome (large inverted sphere) for proper 3D wrapping
